,"y":1491,"w":501,"h":20},{"content":"지급사유에 대해 합의하지 못할 때는 보험수익자와 회사가","x":114,"y":1516,"w":475,"h":20},{"content":"함께 제3자를 정하고 그 제3자의 의견에 따를 수 있습니다.","x":114,"y":1542,"w":475,"h":20},{"content":"제3자는 의료법 제3조(의료기관)에 규정한 종합병원 소속","x":114,"y":1567,"w":475,"h":20},{"content":"전문의 중에 정하며, 보험금 지급사유 판정에 드는 의료비","x":655,"y":87,"w":468,"h":20},{"content":"용은 회사가 전액 부담합니다.","x":655,"y":112,"w":234,"h":20},{"content":"④ 피보험자가 보험기간 중 보장개시일 이후에 사망하고, 그","x":628,"y":137,"w":501,"h":20},{"content":"후에 제3조(‘일반암(소액암제외)’의 정의 및 진단확정)에서","x":659,"y":162,"w":470,"h":20},{"content":"정한 ‘일반암(소액암제외)’을 직접적인 원인으로 사망한 사","x":659,"y":188,"w":463,"h":20},{"content":"실이 확인된 경우에는 그 사망일을 진단 확정일로 보고 제","x":659,"y":213,"w":463,"h":20},{"content":"1조(보험금의 지급사유)에 해당하는 경우에 한하여 해당","x":659,"y":238,"w":470,"h":20},{"content":"보험금을 지급합니다. 다만, 제5조(보장의 소멸) 제2항에","x":659,"y":263,"w":470,"h":20},{"content":"따라 이 보장의 계약자적립액을 지급한 경우에는, 이미 지","x":659,"y":289,"w":463,"h":20},{"content":"급된 계약자적립액을 차감하고 그 차액을 지급합니다.","x":659,"y":314,"w":421,"h":20},{"content":"⑤ 「호스피스·완화의료 및 임종과정에 있는 환자의 연명의료","x":628,"y":339,"w":501,"h":20},{"content":"결정에 관한 법률」에 따른 연명의료중단등결정 및 그 이행","x":655,"y":364,"w":468,"h":20},{"content":"으로 피보험자가 사망하는 경우 연명의료중단등결정 및 그","x":655,"y":390,"w":475,"h":20},{"content":"이행은 제4항 ‘사망’의 원인에 영향을 미치지 않습니다.","x":655,"y":415,"w":430,"h":20},{"content":"제3조(‘일반암(소액암제외)’의 정의 및 진단확정)","x":628,"y":475,"w":432,"h":22},{"content":"●","x":1099,"y":475,"w":21,"h":22},{"content":"① 이 보장에서 ‘일반암(소액암제외)’이라 함은 한국표준질병·사","x":628,"y":512,"w":494,"h":20},{"content":"인분류 에 있어서 악성신생물(암)로 분류되는 질병(‘[별표4]","x":656,"y":537,"w":473,"h":20},{"content":"악성신생물(암) 분류표’ 참조) 중 분류번호 C50(유방의 악성","x":656,"y":563,"w":467,"h":20},{"content":"신생물)에 해당하는 질병, 분류번호 C53(자궁경부의 악성신","x":656,"y":588,"w":467,"h":20},{"content":"생물)에 해당하는 질병, 분류번호 C54(자궁체부의 악성신생","x":656,"y":613,"w":467,"h":20},{"content":"물)에 해당하는 질병, 분류번호 C61(전립선의 악성신생물)","x":656,"y":638,"w":467,"h":20},{"content":"에 해당하는 질병, 분류번호 C67(방광의 악성신생물)에 해","x":656,"y":663,"w":467,"h":20},{"content":"당하는 질병, 분류번호 C44(기타 피부의 악성신생물)에 해","x":656,"y":689,"w":467,"h":20},{"content":"당하는 질병, 분류번호 C73(갑상선의 악성신생물)에 해당하","x":656,"y":714,"w":467,"h":20},{"content":"는 질병 또는 전암(前癌)상태(암으로 변하기 이전 상태)","x":656,"y":739,"w":473,"h":20},{"content":"(Premalignant condition or condition with malignant","x":656,"y":765,"w":473,"h":20},{"content":"potential)를 제외한 질병을 말합니다.","x":656,"y":790,"w":306,"h":20},{"content":"② ‘일반암(소액암제외)’의 진단확정은 병리 또는 진단검사의학","x":628,"y":815,"w":501,"h":20},{"content":"전문의 자격증을 가진 자에 의하여 내려져야 하며, 이 진단","x":656,"y":840,"w":467,"h":20},{"content":"은 조직(fixed tissue)검사, 미세바늘흡인검사(fine needle","x":656,"y":865,"w":473,"h":20},{"content":"aspiration) 또는 혈액(hemic system)검사에 대한 현미경 소","x":656,"y":891,"w":467,"h":20},{"content":"견을 기초로 하여야 하며, 이 경우 ‘일반암(소액암제외)’의","x":656,"y":916,"w":473,"h":20},{"content":"진단확정 시점은 상기 검사에 의한 결과보고 시점으로 합","x":656,"y":941,"w":467,"h":20},{"content":"니다.","x":656,"y":966,"w":38,"h":20},{"content":"③ 제2항에 따른 상기의 병리학적 진단이 가능하지 않을 때","x":628,"y":992,"w":501,"h":20},{"content":"에는 피보험자가 ‘일반암(소액암제외)’으로 진단 또는 치료","x":657,"y":1017,"w":466,"h":20},{"content":"를 받고 있음을 증명할 만한 문서화된 기록 또는 증거가","x":657,"y":1042,"w":472,"h":20},{"content":"있어야 합니다.","x":657,"y":1067,"w":115,"h":20},{"content":"<병리학적 진단이 가능하지 않을 때 예시>","x":682,"y":1117,"w":387,"h":24},{"content":"· 피보험자가 조직검사 등 병리학적 검사를 받을 여유없이","x":640,"y":1151,"w":478,"h":20},{"content":"급속한 병증 악화로 사망한 경우","x":651,"y":1176,"w":257,"h":20},{"content":"· 종양의 발생부위 및 피보험자의 신체상태 등의 이유로","x":640,"y":1201,"w":445,"h":20},{"content":"조직을 추출하는 경우 생명의 위험을 초래할 수 있어","x":651,"y":1226,"w":426,"h":20},{"content":"병리학적 검사를 시행할 수 없는 경우","x":651,"y":1252,"w":300,"h":20},{"content":"유의사항","x":640,"y":1325,"w":85,"h":24},{"content":"•••","x":727,"y":1325,"w":32,"h":24},{"content":"한국표준질병·사인분류 지침서의 “사망 및 질병이환의 분류","x":640,"y":1359,"w":471,"h":20},{"content":"번호 부여를 위한 선정준칙과 지침”에 따라 C77~C80(불명","x":640,"y":1384,"w":471,"h":20},{"content":"확한, 이차성 및 상세불명 부위의 악성신생물(암))의 경우","x":640,"y":1409,"w":478,"h":20}