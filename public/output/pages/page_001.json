{"texts":[{"content":"반드시알아두실사항","x":86,"y":731,"w":204,"h":24},{"content":"1.","x":86,"y":768,"w":14,"h":18},{"content":"보장의개시","x":105,"y":768,"w":81,"h":18},{"content":"회사의보장개시는회사가계약의청약을승낙하고제1회보험료를받은때부터","x":105,"y":790,"w":472,"h":16},{"content":"시작됩니다. 기타자세한내용은약관의\"제1회보험료및회사의보장개시\"를","x":105,"y":810,"w":472,"h":16},{"content":"참고하시기바랍니다.","x":105,"y":830,"w":127,"h":16},{"content":"2. 비례보상안내","x":86,"y":860,"w":115,"h":18},{"content":"실손의료비담보및배상책임, 교통사고처리지원금, 벌금담보등은보험금을","x":105,"y":882,"w":472,"h":16},{"content":"지급할다수의계약이체결되어있는경우, 약관에따라비례보상합니다.","x":105,"y":902,"w":430,"h":16},{"content":"3. 계약자주소변경","x":86,"y":932,"w":129,"h":18},{"content":"보험계약후계약자의주소또는연락처가변경된경우에는지체없이변경사실을","x":105,"y":954,"w":472,"h":16},{"content":"회사에알려야합니다. 이때주소변경을통보하지않은한보험증권에기재된","x":105,"y":974,"w":472,"h":16},{"content":"계약자의주소를회사의의사표시를수령할지정장소로합니다.","x":105,"y":994,"w":377,"h":16},{"content":"4. 상담안내및분쟁해결","x":86,"y":1024,"w":165,"h":18},{"content":"이보험에관하여궁금한점이있을경우에는당사고객서비스센터로문의하여","x":105,"y":1046,"w":472,"h":16},{"content":"주시고보험에관한분쟁이있을때에는금융감독원에진정또는분쟁조정을","x":105,"y":1066,"w":472,"h":16},{"content":"신청하시면도와드립니다.","x":105,"y":1086,"w":153,"h":16},{"content":"5. 보험금청구시구비서류(등기우편접수)","x":86,"y":1116,"w":269,"h":18},{"content":"①사고보고서(회사양식)  ②진단서③치료비영수증원본","x":105,"y":1138,"w":351,"h":16},{"content":"④기타회사가추가로요구하는서류","x":105,"y":1158,"w":220,"h":16},{"content":"예금자보호안내","x":86,"y":1200,"w":146,"h":24},{"content":"1.","x":86,"y":1238,"w":10,"h":16},{"content":"이보험계약은예금자보호법에따라해약환급금(또는만기시보험금)에기타지급","x":105,"y":1238,"w":472,"h":16},{"content":"금을합한금액이1인당“1억원까지”(본보험회사의여타보호상품과합산) 보호됩","x":105,"y":1258,"w":472,"h":16},{"content":"니다. 이와별도로본보험회사보호상품의사고보험금을합산한금액이1인당“1억","x":105,"y":1278,"w":472,"h":16},{"content":"원까지”보호됩니다. 다만, 보험계약자및보험료납부자가법인인보험계약의경우","x":105,"y":1299,"w":472,"h":16},{"content":"에는보호되지않습니다.","x":105,"y":1319,"w":140,"h":16},{"content":"2.","x":86,"y":1347,"w":11,"h":16},{"content":"본보험회사가예금등채권의지급정지후파산하게되는경우, 예금보험공사가보","x":105,"y":1347,"w":472,"h":16},{"content":"험계약자1인당해약환급금(또는만기시보험금)에기타지급금을합한금액및사","x":105,"y":1368,"w":472,"h":16},{"content":"고보험금을각각별도로최고1억원까지보호합니다.(단, 연금저축보험*은다른예","x":105,"y":1388,"w":472,"h":16},{"content":"금보호대상금융상품과는별도로1인당최고1억원까지보호)","x":105,"y":1408,"w":353,"h":16},{"content":"*","x":105,"y":1432,"w":7,"h":16},{"content":"연금저축계좌, 개인연금저축, 연금저축포함","x":115,"y":1428,"w":249,"h":16},{"content":"3.","x":86,"y":1457,"w":12,"h":16},{"content":"위내용은예금자보호법및관련법령의개정에따라달라질수있음을알려드리","x":105,"y":1457,"w":472,"h":16},{"content":"며, 자세한내용은영업점에비치된예금자보호안내책자등을참고하시거나예금","x":105,"y":1477,"w":472,"h":16},{"content":"보험공사(☎1588-0037, www.kdic.or.kr)로문의하시기바랍니다.","x":105,"y":1497,"w":380,"h":16},{"content":"보험계약확인사항","x":623,"y":731,"w":175,"h":24},{"content":"1.","x":623,"y":768,"w":14,"h":18},{"content":"보험가입시청약확인서를본인이자필로서명하셨습니까?","x":642,"y":768,"w":390,"h":18},{"content":"본인이직접청약확인서에서명하셔야만보험금지급이보장됩니다. 단, 전화녹취에","x":642,"y":790,"w":472,"h":16},{"content":"의한청약의경우계약자및피보험자의전화녹취로자필서명을대신합니다.","x":642,"y":810,"w":453,"h":16},{"content":"2. 보험가입시청약서질문사항을사실대로알리셨습니까?","x":623,"y":834,"w":389,"h":18},{"content":"본인의「과거와현재의건강상태」및「직업」등을사실대로알리지않았을경우","x":642,"y":856,"w":472,"h":16},{"content":"보험금지급사유발생시에도보험금을받지못하는경우가있습니다.","x":642,"y":876,"w":408,"h":16},{"content":"3. 계약자보관용청약서와보험약관을받으셨습니까?","x":623,"y":900,"w":361,"h":18},{"content":"계약자보관용청약서및보험약관은회사가고객에게반드시드리게되어있으니","x":642,"y":922,"w":472,"h":16},{"content":"수령하셔서모집인등이설명한내용과일치하는지확인하시기바랍니다.","x":642,"y":942,"w":440,"h":16},{"content":"4. 보험료영수증을받으셨습니까?","x":623,"y":966,"w":233,"h":18},{"content":"보험료를납입할때에는회사가발행한영수증을반드시받으시기바랍니다.","x":642,"y":988,"w":472,"h":16},{"content":"다만, 금융기관에자동이체또는카드로납입하는경우에는통장에기재된내용","x":642,"y":1008,"w":472,"h":16},{"content":"또는카드사용명세서에기재된내용이영수증과동일한효력을가집니다.","x":642,"y":1029,"w":440,"h":16},{"content":"소비자보호기구설치운영","x":623,"y":1074,"w":232,"h":24},{"content":"보험계약과보상등에불편한사항이있으시면, 당사소비자보호상담실(전화02-","x":623,"y":1112,"w":491,"h":16},{"content":"2260-6939)로연락을주시면성심껏상담해드리겠습니다.","x":623,"y":1132,"w":355,"h":16},{"content":"*","x":623,"y":1366,"w":8,"h":16},{"content":"본계약의보험기간만료후갱신(재가입)하지않는경우에는이증권으로","x":635,"y":1362,"w":479,"h":16},{"content":"계약의유효를주장할수없습니다.","x":635,"y":1382,"w":215,"h":16},{"content":"저희회사는보험계약자와해당보험약관이정하는바에따라보험계약을체결","x":634,"y":1426,"w":469,"h":16},{"content":"하고그증거로이보험증권을드립니다.","x":634,"y":1447,"w":243,"h":16},{"content":"본보험증권은법령및내부통제기준에따른절차를거쳐금융소비자에게","x":634,"y":1467,"w":469,"h":16},{"content":"제공되는문서입니다.","x":634,"y":1487,"w":128,"h":16},{"content":"AIG","x":725,"y":1211,"w":45,"h":28},{"content":"손해보험고객서비스센터","x":770,"y":1212,"w":242,"h":24},{"content":"대한민국정부","x":1030,"y":1561,"w":79,"h":14},{"content":"인","x":1030,"y":1577,"w":11,"h":14},{"content":"지","x":1064,"y":1577,"w":11,"h":14},{"content":"세","x":1097,"y":1577,"w":11,"h":14},{"content":"1","x":1030,"y":1593,"w":8,"h":14},{"content":"0","x":1053,"y":1593,"w":8,"h":14},{"content":"0","x":1075,"y":1593,"w":8,"h":14},{"content":"원","x":1097,"y":1593,"w":11,"h":14},{"content":"영등포세무서장","x":1030,"y":1609,"w":79,"h":14},{"content":"후납승인2017","x":1030,"y":1626,"w":51,"h":14},{"content":"-","x":1080,"y":1626,"w":4,"h":14},{"content":"33234","x":1083,"y":1626,"w":26,"h":14},{"content":"전남 고흥군 포두면 남성3길 18","x":686,"y":364,"w":280,"h":20},{"content":"(남성리)","x":686,"y":385,"w":71,"h":20},{"content":"김선아 고객님","x":728,"y":411,"w":149,"h":24},{"content":"5 9 5 2 7","x":923,"y":453,"w":88,"h":24},{"content":"��������������������","x":602,"y":329,"w":69,"h":10},{"content":"��������������������","x":602,"y":353,"w":69,"h":10},{"content":"��������������������","x":602,"y":377,"w":69,"h":10},{"content":"1102426611627000002026041016014520002014280","x":686,"y":341,"w":396,"h":20},{"content":"L0530-1","x":686,"y":314,"w":104,"h":26},{"content":"11024266116270000020260410160145_20002014280","x":0,"y":9,"w":249,"h":10},{"content":"No : 1(000001) 【 1/139 】","x":685,"y":26,"w":206,"h":16},{"content":"<1>","x":1114,"y":26,"w":29,"h":16}]}