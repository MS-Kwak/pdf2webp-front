"y":403,"w":779,"h":17},{"content":"(기준: 남자,40세,[갱신형]암직접치료(요양병원제외)입원비(4일이상 120일한도)(간편심사)5만원,10년만기,10년납)","x":57,"y":440,"w":869,"h":17},{"content":"보장범위지수(%)","x":528,"y":473,"w":144,"h":20},{"content":"144.1%","x":571,"y":513,"w":58,"h":20},{"content":"주) 1. 보장범위지수는 기본 가입조건에 따른 보장수준을 나타내므로, 보장수준이 높아질 경우 보험료가 높아질 수 있음.","x":57,"y":551,"w":779,"h":17},{"content":"라.보험금 지급 관련 유의사항","x":57,"y":590,"w":355,"h":28},{"content":"※아래의 유의사항은 보험계약자의","x":74,"y":629,"w":234,"h":17},{"content":"오해를 방지","x":306,"y":629,"w":81,"h":17},{"content":"하기 위해","x":386,"y":629,"w":68,"h":17},{"content":"보험금지급에 관한 약관내용의 일부","x":453,"y":629,"w":241,"h":17},{"content":"를","x":692,"y":629,"w":20,"h":17},{"content":"선별하여 요약한 것","x":711,"y":629,"w":132,"h":17},{"content":"이므로 보다","x":841,"y":629,"w":83,"h":17},{"content":"자세한 내용은 약관을 필히 확인","x":922,"y":629,"w":218,"h":17},{"content":"하시기 바랍니다.","x":74,"y":652,"w":115,"h":17},{"content":"■","x":74,"y":687,"w":26,"h":19},{"content":"상해(인보험)공통조항","x":99,"y":687,"w":174,"h":19},{"content":"① 회사는 그 원인의 직접 간접을 묻지 아니하고 아래의 사유로 생긴 손해는 보상하여 드리지 않습니다.","x":106,"y":717,"w":819,"h":19},{"content":"* 피보험자의 고의","x":131,"y":748,"w":145,"h":19},{"content":"* 계약자의 고의","x":131,"y":773,"w":128,"h":19},{"content":"* 보험수익자의 고의","x":131,"y":797,"w":162,"h":19},{"content":"* 피보험자의 임신, 출산(제왕절개 포함), 산후기, 그러나 회사가 보장하는 보험금 지급사유로 인한 경우에는 지급","x":131,"y":822,"w":891,"h":19},{"content":"* 전쟁","x":131,"y":847,"w":51,"h":19},{"content":", 외국의 무력행사, 혁명, 내란, 사변, 폭등","x":182,"y":847,"w":330,"h":19},{"content":"③ 회사는 아래의 사유를 원인으로 하여 보험금 지급사유가 발생한 때에는 보험금을 지급하지 않습니다.","x":106,"y":878,"w":820,"h":19},{"content":"* 피보험자의 선천성기형, 선천적질환 및 이에 근거한 상병","x":131,"y":908,"w":463,"h":19},{"content":"* 알콜중독, 습관성 약품 또는 환각제의 복용 및 사용","x":131,"y":933,"w":420,"h":19},{"content":"[ 인보험에 관한 사항 ]","x":74,"y":969,"w":213,"h":22},{"content":"1. 후유장해의 경우 치료받은 병원이 아닌 다른 병원에서 진단받을 경우 심사기간이 길어질 수 있으므로 주치료병원이나 수술받은","x":106,"y":1003,"w":1022,"h":19},{"content":"3차 의료기관에서 진단받는 것을 권해 드립니다.","x":106,"y":1028,"w":404,"h":19},{"content":"2. 간혹 의사가 진단을 부정확하게 할 수 있으며, 이러한 경우에는 추가적인 확인을 거쳐 최종 진단을 확정합니다.","x":106,"y":1053,"w":897,"h":19},{"content":"3. 한방병원에서 치료 목적이 아닌 단순한 건강증진을 위한 첩약은 보상되지 않습니다.","x":106,"y":1078,"w":682,"h":19},{"content":"[ 암보험 및 수술에 관한 사항 ]","x":74,"y":1114,"w":291,"h":22},{"content":"<암보험>","x":106,"y":1148,"w":68,"h":19},{"content":"ㅇ 보험계약일로부터 90일 이내에 암으로 진단받은 경우에는 보험금을 지급하지 않습니다.","x":106,"y":1178,"w":714,"h":19},{"content":"ㅇ 90일이 경과한 이후에도 암 진단일이 보험계약일로부터 일정기간(예:180일, 1년, 2년 등) 이내인 경우 보험금이 삭감될 수","x":106,"y":1203,"w":978,"h":19},{"content":"있습니다.","x":106,"y":1228,"w":98,"h":19},{"content":"ㅇ 암은 원칙적으로 조직검사, 미세바늘흡인검사(미세한 침을 이용한 생체검사 방법) 또는 혈액검사에 대한 현미경 소견을","x":106,"y":1253,"w":959,"h":19},{"content":"기초로 한 진단만 인정됩니다.","x":106,"y":1278,"w":259,"h":19},{"content":"ㅇ 한국표준질병·사인분류 지침서의 “사망 및 질병이환의 분류번호 부여를 위한 선정준칙과 지침”에 따라 C77~C80(불명확한,","x":106,"y":1302,"w":1023,"h":19},{"content":"이차성 및 상세불명 부위의 악성신생물(암))의 경우 일차성 악성신생물(암)이 확인되는 경우에는 원발부위(최초 발생한 부위)를","x":106,"y":1327,"w":1022,"h":19},{"content":"기준으로 분류합니다.","x":106,"y":1352,"w":200,"h":19},{"content":"다만, 이 경우에도 원발부위의 암이 완치되었다면 이차성 및 상세불명 부위의 악성신생물(암)(C77~C80)의 진단확정 시점은","x":106,"y":1377,"w":970,"h":19},{"content":"원발암진단확정 시점으로 변경되지 않습니다.","x":106,"y":1402,"w":355,"h":19},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000031) 【 31/139 】","x":676,"y":26,"w":215,"h":16},{"content":"<31>","x":1105,"y":26,"w":39,"h":16}]}