{"texts":[{"content":"07326","x":719,"y":1574,"w":41,"h":16},{"content":"서울시영등포구국제금융로","x":760,"y":1573,"w":170,"h":17},{"content":"10","x":932,"y":1574,"w":17,"h":16},{"content":"국제금융센터","x":949,"y":1573,"w":81,"h":17},{"content":"Two IFC 27","x":1033,"y":1574,"w":70,"h":16},{"content":"층","x":1102,"y":1573,"w":15,"h":16},{"content":"AIG","x":876,"y":1606,"w":46,"h":28},{"content":"손해보험주식회사","x":923,"y":1604,"w":194,"h":26},{"content":"상품설명서","x":240,"y":61,"w":200,"h":44},{"content":"무배당 AIG 든든한 간편암보험2604(325간편심사형)(10년갱신형)","x":82,"y":146,"w":1039,"h":36},{"content":"설계번호 : 942696462419","x":886,"y":197,"w":252,"h":22},{"content":"상품개발자","x":69,"y":1579,"w":80,"h":16},{"content":"윤인선((02)2260-6800)","x":166,"y":1579,"w":181,"h":16},{"content":"모집인소속","x":69,"y":1597,"w":80,"h":16},{"content":"보험대리점 ㈜에이아이지어드바이저_LTC2(AA)","x":166,"y":1597,"w":343,"h":16},{"content":"모","x":69,"y":1616,"w":15,"h":16},{"content":"집","x":101,"y":1616,"w":15,"h":16},{"content":"인","x":133,"y":1616,"w":15,"h":16},{"content":"위지영 (고유번호 : 20150485120007)","x":166,"y":1616,"w":279,"h":16},{"content":"연","x":69,"y":1635,"w":15,"h":16},{"content":"락","x":101,"y":1635,"w":15,"h":16},{"content":"처","x":133,"y":1635,"w":15,"h":16},{"content":"(02)6430-4700","x":166,"y":1635,"w":124,"h":16},{"content":"발행일시","x":69,"y":1654,"w":80,"h":16},{"content":"2026년 04월 10일","x":166,"y":1654,"w":145,"h":16},{"content":"고객센터","x":69,"y":1673,"w":80,"h":16},{"content":"1544-2792","x":166,"y":1673,"w":91,"h":16},{"content":"관리번호","x":756,"y":1633,"w":80,"h":16},{"content":":  AIG 상품관리 제2026-4-TM-P035호","x":854,"y":1633,"w":284,"h":16},{"content":"④ 계약변경에 관한 사항","x":74,"y":286,"w":229,"h":22},{"content":"회사의 승낙을 얻어 보험계약자를 변경한 경우, 변경된 계약자에게 보험증권 및 약관을 교부하고 변경된 계약자가 요청하는 경우","x":106,"y":319,"w":1016,"h":19},{"content":"약관의 중요한 내용을 설명하여 드립니다. 보험료 감액시 환급금이 없거나 최초가입시 안내한 만기(해지)환급금보다 현저히 적어","x":106,"y":344,"w":1010,"h":19},{"content":"질 수 있습니다.","x":106,"y":369,"w":125,"h":19},{"content":"⑤ 보험사기에 관한 사항","x":74,"y":405,"w":229,"h":22},{"content":"보험사기(고의사고, 허위사고, 허위입원, 진단, 장해, 사고 후 보험가입 등)는 보험사기방지 특별법 및 형법상 금지된 범죄입니다.","x":106,"y":439,"w":1008,"h":19},{"content":"⑥ 보험금 대리 청구인 지정에 관한사항","x":74,"y":475,"w":368,"h":22},{"content":"□ 보험금 대리청구인 제도란?","x":106,"y":509,"w":241,"h":19},{"content":"보험사고(예 : 치매 등) 발생으로 본인 스스로 보험금 청구가 현실적으로 어려운 상황이 발생할 경우 보험금을 대신 청구하는 자","x":131,"y":539,"w":1008,"h":19},{"content":"(보험금 대리청구인)를 보험가입초기 또는 유지 중에 미리 지정하는 제도입니다.","x":131,"y":564,"w":628,"h":19},{"content":"<치매보험 등 대리청구인 지정 FAQ>","x":131,"y":595,"w":288,"h":19},{"content":"Q. 대리청구인 지정은 언제?","x":131,"y":620,"w":224,"h":19},{"content":"A. 가입 시 또는 보험기간(계약유지) 중에 모두 가능하나, 언제 발생할지 모르는 보험사고로 인한 보험금 청구 불능에","x":131,"y":645,"w":923,"h":19},{"content":"대비하기 위해 청약 시점에 지정하는 것을 권장합니다.","x":131,"y":669,"w":454,"h":19},{"content":"Q. 대리청구인 지정 범위는?","x":131,"y":694,"w":224,"h":19},{"content":"A. 피보험자의 가족관계등록부(또는 주민등록표)* 상 배우자 또는 피보험자의 3촌 이내의 친족 가운데 지정할 수 있습니다.","x":131,"y":719,"w":966,"h":19},{"content":"Q. 몇 명까지 지정 가능한지?","x":131,"y":744,"w":232,"h":19},{"content":"A. 두 명까지 지정 가능하며, 대리인을 두 명 지정하는 때에는 그 두 명 가운데 대표대리인을 지정*해야 합니다.","x":131,"y":769,"w":881,"h":19},{"content":"* [참 고] 두 명의 청구대리인이 지정된 때, 그 중 대표대리인이 보험금을 청구하고 수령할 수 있으며, 대표대리인이 사망","x":131,"y":794,"w":953,"h":19},{"content":"등의 사유로 보험금 청구가 불가능한 때에 한해 대표가 아닌 청구대리인이 보험금을 청구·수령할 수 있습니다.","x":131,"y":819,"w":896,"h":19},{"content":"※ 보다 자세한 사항은 약관을 참조하시기 바랍니다.","x":131,"y":849,"w":413,"h":19},{"content":"□ 보험금 대리청구인은 왜 지정해야 하나요?","x":106,"y":880,"w":359,"h":19},{"content":"보험계약은 질병(치매 등)이나 상해 등의 보험사고 발생시 가입자 등이 보험금을 청구해야만 보험금이 지급되는 상품의 특징으","x":131,"y":910,"w":996,"h":19},{"content":"로 인해 계약자가 본인을 위한(계약자=피보험자=보험수익자) 보험상품에 가입한 후 보험사고 발생시 인식불명 등으로 본인이 보","x":131,"y":935,"w":1011,"h":19},{"content":"험금을 청구할 수 없는 상황이 발생할 수 있습니다.","x":131,"y":960,"w":404,"h":19},{"content":"※ 예시 : 계약자가 자신을 위한 치매보험 가입 후 치매가 발생한 경우","x":179,"y":985,"w":556,"h":19},{"content":"☞ 계약자가 보험금을 직접 청구할 수 없어 치매보험금 청구가 곤란","x":131,"y":1010,"w":583,"h":19},{"content":"☞ 이런 경우에 대비하여 보험금 대리청구인을 미리 지정하여 두시면 대리청구인이 가입자(계약자)를 대신하여 보험금을 청구할","x":131,"y":1035,"w":1006,"h":19},{"content":"수 있습니다.","x":131,"y":1060,"w":99,"h":19},{"content":"□ 보험금 대리청구인 지정 방법","x":106,"y":1090,"w":256,"h":19},{"content":"가입하신 계약 중 본인을 위한 계약","x":131,"y":1121,"w":281,"h":19},{"content":"「보험계약자 = 피보험자 = 보험수익자」","x":411,"y":1121,"w":329,"h":19},{"content":"의 경우 아래의 연락처를 통해 보험회사에 대리청","x":739,"y":1121,"w":391,"h":19},{"content":"구인 지정을 신청하실 수 있습니다.","x":131,"y":1146,"w":277,"h":19},{"content":"※ 대리청구인 신청 연락처 : 1544-2792","x":131,"y":1170,"w":316,"h":19},{"content":"□ 보험금 대리청구인 신청 서류","x":106,"y":1201,"w":256,"h":19},{"content":"* 피보험자와 3촌 이내 친족 또는 동거하는 세대구성원, 배우자임이 확인되는 가족관계증명서 또는 주민등록등·초본","x":131,"y":1232,"w":923,"h":19},{"content":"* 계약자 신분증 앞면 사본","x":131,"y":1256,"w":212,"h":19},{"content":"* 지정대리 청구인 신분증 앞면 사본","x":131,"y":1281,"w":289,"h":19},{"content":"⑦ 상속인 금융거래 조회서비스에 관한 사항","x":74,"y":1318,"w":408,"h":22},{"content":"상속인 등이 피상속인(사망자)의 보험, 예금, 대출 등 금융거래계좌를 확인하기 위하여 다수 금융회사를 일일이 방문해야 하는","x":106,"y":1351,"w":989,"h":19},{"content":"불편을 덜어주고자","x":106,"y":1376,"w":154,"h":19},{"content":"금융감독원 (금감원 통합콜센터 1332)","x":259,"y":1376,"w":293,"h":19},{"content":"에서 조회를 원하는 상속인 등에게 금융계좌 보유 유무를 일괄 조회할","x":550,"y":1376,"w":552,"h":19},{"content":"수 있도록 해주는 상속인 금융거래 조회서비스를 제공하고 있습니다.","x":106,"y":1401,"w":541,"h":19},{"content":"■","x":106,"y":1426,"w":26,"h":19},{"content":"구비서류","x":131,"y":1426,"w":70,"h":19},{"content":": 사망사실(사망일자포함)이 기재된 기본증명서 또는 사망진단서, 가족관계증명서(최근 3개월내 발급), 상속인 신분증","x":199,"y":1426,"w":921,"h":19},{"content":"※ 피상속인이 사망하지 않은 경우라도 피보험자가 법원으로부터 실종자,금치산자 도는 피성년후견인으로 선고받은 경우 상속인","x":106,"y":1451,"w":1025,"h":19},{"content":"금융거래 조회서비스를 이용하실 수 있습니다","x":106,"y":1476,"w":398,"h":19},{"content":"* 구비서류","x":122,"y":1500,"w":85,"h":19},{"content":": 상속인 직접 신청시 필요서류 법원판결문(원본), 등기사항 증명서(후겨인 및 대리인 범위 확인)","x":206,"y":1500,"w":761,"h":19},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000037) 【 37/139 】","x":676,"y":26,"w":215,"h":16},{"content":"<37>","x":1105,"y":26,"w":39,"h":16}]}