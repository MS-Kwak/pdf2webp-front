"w":248,"h":19},{"content":"보험계약을 부활 하였고 부활일로부터 90일 이내에 유방암 진단을 받아 보험회사에 암 진단금을 청구하였으나,","x":136,"y":632,"w":875,"h":19},{"content":"보험회사가 90일간의 면책기간 이내의 진단이라는 사유로 보험금 지급을 거절함에 민원 접수","x":136,"y":657,"w":734,"h":19},{"content":"보험계약을 부활하는 경우 암보험은 부활일자를 기준으로 면책기간이 적용됨. 따라서 90일간의 면책기간 중 암진","x":136,"y":688,"w":892,"h":19},{"content":"단에 대해서는 보험사의 보험금 지급책임이 발생하지 않음","x":136,"y":713,"w":460,"h":19},{"content":"유형","x":139,"y":759,"w":35,"h":19},{"content":"일반심사형 보험 상품과 유병자 간편 상품 보험료 비교","x":189,"y":759,"w":434,"h":19},{"content":"동일한 보장으로 보험 가입한 지인과 비교해 보험료가 비싸다는 불만을 접수","x":136,"y":814,"w":604,"h":19},{"content":"계약 전 알릴의무 항목을 간소화하여 유병력자 등 일반심사 보험에 가입하기 어려운 피보험자를 대상으로 계약심","x":136,"y":845,"w":892,"h":19},{"content":"사 부담을 줄여 가입할 수 있도록 한 유병자형 상품으로 일반심사보험 대비 보험료가 할증되어 있습니다.","x":136,"y":869,"w":828,"h":19},{"content":"유형","x":140,"y":916,"w":35,"h":19},{"content":"계약 전 알릴의무 위반","x":190,"y":916,"w":179,"h":19},{"content":"사례1: 갱년기 호르몬제 복용중이나 중년에 대부분 복용하는 것으로 질병으로 생각하지 않아 청약 시 고지하지","x":136,"y":971,"w":869,"h":19},{"content":"않았으나 해당 사유로 계약이 해지됨","x":136,"y":995,"w":290,"h":19},{"content":"사례2: 경미한 접촉사고로 몇 일 통원치료 후 별다른 증상이 없어 보험 가입 시 해당 사고를 고지하지 않았으나","x":136,"y":1020,"w":879,"h":19},{"content":"해당 사유로 계약이 해지됨","x":136,"y":1045,"w":213,"h":19},{"content":"사례3: C씨는 모집인에게 간질환으로 치료를 받은 사실을 구두로 얘기하고 보험을 가입한 후 간경화로 입원치료","x":136,"y":1070,"w":884,"h":19},{"content":"를 받고 청구하였으나 가입 시 간질환 치료사실을 고지하지 않았다는 사유로 계약을 해지하고 보험금도 지급하지","x":136,"y":1095,"w":892,"h":19},{"content":"않음","x":136,"y":1120,"w":35,"h":19},{"content":"보험 청약 시 청약서 계약 전 알릴의무에 해당하는 병력 및 치료사실에 대해서는 사실대로 알려야 하며, 사실대","x":136,"y":1150,"w":879,"h":19},{"content":"로 알리지 않은 경우 계약 전 알릴의무 위반으로 계약이 해지되거나 보험금이 지급되지 않을 수 있습니다.","x":136,"y":1175,"w":837,"h":19},{"content":"고지수령권이 없는 모집인에게 구두 통보한 것은 고지한 것이 아니며, 청약서에 최종 기재되어야만 고지의무를","x":136,"y":1200,"w":872,"h":19},{"content":"이행한 것으로 봅니다. 보험 가입 시 청약서의 기재여부를 반드시 확인하고 서명하시기 바랍니다.","x":136,"y":1225,"w":766,"h":19},{"content":"전화 등 통신수단을 통해 가입한 경우 판매자의 질문에 답하고 이를 녹음하는 방식으로 계약 전 알릴의무를 이행","x":136,"y":1250,"w":891,"h":19},{"content":"하여야 하므로 답변에 신중하여야 합니다.","x":136,"y":1275,"w":329,"h":19},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000018) 【 18/139 】","x":676,"y":26,"w":215,"h":16},{"content":"<18>","x":1105,"y":26,"w":39,"h":16}]}