{"texts":[{"content":"【별표1 】","x":89,"y":87,"w":81,"h":20},{"content":"보험금을 지급할 때의 적립이율 계산","x":178,"y":137,"w":309,"h":20},{"content":"구분","x":121,"y":203,"w":35,"h":20},{"content":"기간","x":263,"y":203,"w":43,"h":20},{"content":"지급이자","x":448,"y":203,"w":69,"h":20},{"content":"보통약관","x":104,"y":288,"w":77,"h":20},{"content":"및","x":129,"y":313,"w":26,"h":20},{"content":"특별약관","x":104,"y":339,"w":77,"h":20},{"content":"보장","x":121,"y":364,"w":42,"h":20},{"content":"보험금","x":112,"y":389,"w":53,"h":20},{"content":"지급기일의 다음 날","x":208,"y":235,"w":155,"h":20},{"content":"부터 30일 이내 기간","x":203,"y":260,"w":166,"h":20},{"content":"보험계약대출이율","x":413,"y":247,"w":138,"h":20},{"content":"지급기일의 31일이후","x":203,"y":296,"w":165,"h":20},{"content":"부터 60일이내 기간","x":207,"y":321,"w":157,"h":20},{"content":"보험계약대출이율+","x":408,"y":296,"w":156,"h":20},{"content":"가산이율(4.0%)","x":425,"y":321,"w":116,"h":20},{"content":"지급기일의 61일이후","x":203,"y":356,"w":165,"h":20},{"content":"부터 90일이내 기간","x":207,"y":381,"w":157,"h":20},{"content":"보험계약대출이율+","x":408,"y":356,"w":156,"h":20},{"content":"가산이율(6.0%)","x":425,"y":381,"w":116,"h":20},{"content":"지급기일의 91일이후","x":209,"y":417,"w":161,"h":20},{"content":"기간","x":269,"y":442,"w":35,"h":20},{"content":"보험계약대출이율+","x":408,"y":417,"w":156,"h":20},{"content":"가산이율(8.0%)","x":425,"y":442,"w":116,"h":20},{"content":"만기","x":121,"y":513,"w":36,"h":20},{"content":"환급금","x":112,"y":538,"w":60,"h":20},{"content":"및 해약","x":108,"y":563,"w":62,"h":20},{"content":"환급금","x":112,"y":588,"w":53,"h":20},{"content":"지급사유가 발생한","x":212,"y":491,"w":147,"h":20},{"content":"날의 다음날부터","x":221,"y":517,"w":136,"h":20},{"content":"청구일까지의 기간","x":212,"y":542,"w":147,"h":20},{"content":"1년이내","x":451,"y":479,"w":62,"h":20},{"content":": 평균공시이율의 50%","x":397,"y":504,"w":178,"h":20},{"content":"1년초과기간","x":434,"y":535,"w":103,"h":20},{"content":": 평균공시이율의 40%","x":401,"y":560,"w":170,"h":20},{"content":"청구일의 다음 날부터","x":200,"y":595,"w":179,"h":20},{"content":"지급일까지의 기간","x":212,"y":620,"w":147,"h":20},{"content":"보험계약대출이율","x":413,"y":607,"w":138,"h":20},{"content":"주1) 만기환급금은 회사가 보험금의 지급시기 도래 7일 이전에","x":89,"y":659,"w":501,"h":20},{"content":"지급할 사유와 금액을 알리지 않은 경우, 지급사유가 발","x":130,"y":684,"w":453,"h":20},{"content":"생한 날의 다음 날부터 청구일까지의 기간은 평균공시이","x":130,"y":710,"w":453,"h":20},{"content":"율을 적용한 이자를 지급합니다.","x":130,"y":735,"w":251,"h":20},{"content":"주2) 지급이자의 계산은 연단위 복리로 계산하며, 금리연동형","x":89,"y":760,"w":494,"h":20},{"content":"보험은 일자 계산합니다. 단, 보통약관 제1절 일반조항","x":130,"y":786,"w":459,"h":20},{"content":"제38조(소멸시효)에서 정한 소멸시효가 완성된 이후에는","x":130,"y":811,"w":459,"h":20},{"content":"이자를 지급하지 않습니다.","x":130,"y":836,"w":209,"h":20},{"content":"주3) 계약자 등의 책임 있는 사유로 보험금 지급이 지연된 때","x":89,"y":861,"w":494,"h":20},{"content":"에는 그 해당기간에 대한 이자는 지급되지 않을 수 있습","x":130,"y":886,"w":453,"h":20},{"content":"니다. 다만, 회사는 계약자 등이 분쟁조정을 신청했다는","x":130,"y":912,"w":459,"h":20},{"content":"사유만으로 이자지급을 거절하지 않습니다.","x":130,"y":937,"w":336,"h":20},{"content":"주4) 금리연동형보험의 경우 상기 평균공시이율은 적립순보험","x":89,"y":962,"w":494,"h":20},{"content":"료에 대한 적립이율을 말합니다.","x":130,"y":987,"w":251,"h":20},{"content":"주5) 가산이율 적용시 보통약관 제1절 일반조항 제8조(보험금","x":89,"y":1013,"w":494,"h":20},{"content":"의 지급절차) 제2항 각 호의 어느 하나에 해당되는 사유","x":130,"y":1038,"w":453,"h":20},{"content":"로 지연된 경우에는 해당기간에 대하여 가산이율을 적용","x":130,"y":1063,"w":453,"h":20},{"content":"하지 않습니다.","x":130,"y":1088,"w":115,"h":20},{"content":"주6) 가산이율 적용시 금융위원회 또는 금융감독원이 정당한","x":89,"y":1114,"w":501,"h":20},{"content":"사유로 인정하는 경우에는 해당 기간에 대하여 가산이율","x":130,"y":1139,"w":453,"h":20},{"content":"을 적용하지 않습니다.","x":130,"y":1164,"w":174,"h":20},{"content":"주7) 보험사가 해지권을 행사하는 경우 위 표의 ‘청구일’은 보","x":89,"y":1189,"w":494,"h":20},{"content":"험사의 해지 의사표시(서면, 전자우편, 휴대전화 문자메시","x":130,"y":1215,"w":453,"h":20},{"content":"지 또는 이에 준하는 전자적 의사표시 포함)가 보험계약","x":130,"y":1240,"w":453,"h":20},{"content":"자 또는 그의 대리인에게 도달한 날로 봅니다.","x":130,"y":1265,"w":368,"h":20},{"content":"【별표2 】","x":628,"y":87,"w":81,"h":20},{"content":"특정 신체부위·질병보장제한부 분류표 (1) 특정 신체부위","x":650,"y":137,"w":445,"h":21},{"content":"특정 신체부위","x":817,"y":203,"w":111,"h":20},{"content":"1. 위, 십이지장","x":642,"y":229,"w":115,"h":20},{"content":"2. 공장(빈창자), 회장(돌창자) 및 맹장(충수돌기 포함)","x":642,"y":254,"w":392,"h":20},{"content":"3. 대장(맹장, 직장 제외)","x":642,"y":278,"w":179,"h":20},{"content":"4. 직장","x":642,"y":302,"w":56,"h":20},{"content":"5. 항문","x":642,"y":326,"w":56,"h":20},{"content":"6. 간","x":642,"y":350,"w":39,"h":20},{"content":"7. 담낭(쓸개) 및 담관","x":642,"y":375,"w":162,"h":20},{"content":"8. 췌장","x":642,"y":399,"w":56,"h":20},{"content":"9. 비장","x":642,"y":423,"w":56,"h":20},{"content":"10. 기관, 기관지, 폐, 흉막 및 흉곽(늑골(갈비뼈) 포함)","x":642,"y":447,"w":399,"h":20},{"content":"11. 코[외비(코 바깥), 비강(코 안) 및 부비강(코 곁굴)포함]","x":642,"y":471,"w":427,"h":20},{"content":"12. 인두 및 후두(편도 포함)","x":642,"y":496,"w":209,"h":20},{"content":"13. 식도","x":642,"y":520,"w":64,"h":20},{"content":"14.","x":642,"y":544,"w":22,"h":20},{"content":"구강(입속), 치아, 혀, 악하선(턱밑샘), 이하선(귀밑샘) 및","x":671,"y":544,"w":415,"h":20},{"content":"설하선(혀밑샘)","x":672,"y":568,"w":107,"h":20},{"content":"15. 귀[외이(바깥 귀), 고막, 중이(가운데귀), 내이(속귀), 청신경","x":642,"y":592,"w":465,"h":20},{"content":"및 유양돌기(꼭지돌기(귀 뒤에서 만져지는 둥그렇게","x":672,"y":617,"w":390,"h":20},{"content":"돌출된 부분)) 포함]","x":672,"y":641,"w":144,"h":20},{"content":"16.","x":642,"y":665,"w":22,"h":20},{"content":"안구 및 안구부속기[안검(눈꺼풀), 결막, 누기(눈물샘), 안근","x":671,"y":665,"w":439,"h":20},{"content":"및 안와(눈확)내 조직 포함]","x":672,"y":689,"w":201,"h":20},{"content":"17. 신장","x":642,"y":713,"w":64,"h":20},{"content":"18. 부신","x":642,"y":737,"w":64,"h":20},{"content":"19. 요관, 방광 및 요도","x":642,"y":762,"w":173,"h":20},{"content":"20. 음경","x":642,"y":786,"w":64,"h":20},{"content":"21.  질 및 외음부","x":642,"y":810,"w":133,"h":20},{"content":"22. 전립선","x":642,"y":834,"w":80,"h":20},{"content":"23. 유방(유선 포함)","x":642,"y":858,"w":145,"h":20},{"content":"24. 자궁[자궁체부(자궁몸통) 포함]","x":642,"y":883,"w":251,"h":20},{"content":"25. 자궁체부(자궁몸통)(제왕절개술을 받은 경우에 한함)","x":642,"y":907,"w":412,"h":20},{"content":"26. 난소 및 난관","x":642,"y":931,"w":129,"h":20},{"content":"27. 고환[고환초막(고환집막) 포함], 부고환, 정관, 정삭 및","x":642,"y":955,"w":431,"h":20},{"content":"정낭","x":672,"y":979,"w":35,"h":20},{"content":"28. 갑상선","x":642,"y":1004,"w":80,"h":20},{"content":"29. 부갑상선","x":642,"y":1028,"w":97,"h":20},{"content":"30.","x":642,"y":1052,"w":22,"h":20},{"content":"서혜부(넓적다리 부위의 위쪽 주변) (서혜 탈장, 음낭 탈장","x":671,"y":1052,"w":439,"h":20},{"content":"또는 대퇴 탈장이 생긴 경우에 한함)","x":672,"y":1076,"w":272,"h":20},{"content":"31. 피부(두피 및 입술포함)","x":642,"y":1100,"w":201,"h":20},{"content":"32. 경추부(해당신경 포함)","x":642,"y":1125,"w":193,"h":20},{"content":"33. 흉추부(해당신경 포함)","x":642,"y":1149,"w":193,"h":20},{"content":"34. 요추부(해당신경 포함)","x":642,"y":1173,"w":193,"h":20},{"content":"35. 천골(엉치뼈)부 및 미골(꼬리뼈)부 (해당신경 포함)","x":642,"y":1197,"w":398,"h":20},{"content":"36. 왼쪽 어깨","x":642,"y":1221,"w":105,"h":20},{"content":"37. 오른쪽 어깨","x":642,"y":1245,"w":121,"h":20},{"content":"38. 왼팔(왼쪽 어깨 제외, 왼손 포함)","x":642,"y":1270,"w":269,"h":20},{"content":"39. 오른팔(오른쪽 어깨 제외, 오른손 포함)","x":642,"y":1294,"w":317,"h":20},{"content":"40. 왼손(왼쪽 손목 관절 이하)","x":642,"y":1318,"w":225,"h":20},{"content":"41. 오른손(오른쪽 손목 관절 이하)","x":642,"y":1342,"w":258,"h":20},{"content":"42. 왼쪽 고관절","x":642,"y":1366,"w":121,"h":20},{"content":"43. 오른쪽 고관절","x":642,"y":1391,"w":137,"h":20},{"content":"44. 왼쪽 다리(왼쪽 고관절 제외, 왼발 포함)","x":642,"y":1415,"w":326,"h":20},{"content":"45. 오른쪽 다리(오른쪽 고관절 제외, 오른발 포함)","x":642,"y":1439,"w":374,"h":20},{"content":"46. 왼발(왼쪽 발목 관절 이하)","x":642,"y":1463,"w":225,"h":20},{"content":"47. 오른발(오른쪽 발목 관절 이하)","x":642,"y":1487,"w":258,"h":20},{"content":"48. 상·하악골(위턱뼈·아래턱뼈)","x":642,"y":1512,"w":224,"h":20},{"content":"49. 쇄골(빗장뼈)","x":642,"y":1536,"w":120,"h":20},{"content":"50. 늑골(갈비뼈)","x":642,"y":1560,"w":127,"h":20},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000111) 【 111/139 】","x":667,"y":26,"w":225,"h":16},{"content":"<111>","x":1096,"y":26,"w":48,"h":16}]