{"texts":[{"content":"⑥ 피보험자가 회사에서 정한 보험금을 지급하지 않는 기간의","x":89,"y":87,"w":501,"h":20},{"content":"종료일을 포함하여 계속하여 입원한 경우 그 입원에 대해","x":116,"y":112,"w":467,"h":20},{"content":"서는 보험금을 지급하지 않는 기간 종료일의 다음날을 입","x":116,"y":137,"w":467,"h":20},{"content":"원의 개시일로 인정하여 보험금을 지급합니다.","x":116,"y":162,"w":362,"h":20},{"content":"⑦ 피보험자에게 보험사고가 발생했을 경우, 그 사고가 특정","x":89,"y":188,"w":501,"h":20},{"content":"신체부위 또는 특정 질병을 직접적인 원인으로 발생한 사","x":116,"y":213,"w":467,"h":20},{"content":"고인지 아닌지는 의사의 진단서와 의견을 주된 판단자료로","x":116,"y":238,"w":473,"h":20},{"content":"하여결정합니다.","x":116,"y":263,"w":123,"h":20},{"content":"⑧ 제1항의 특정 신체부위와 특정질병을 합하여 4개 이내에서","x":89,"y":289,"w":501,"h":20},{"content":"선택하여 부가할 수 있습니다.","x":116,"y":314,"w":234,"h":20},{"content":"제3조(해지된 특별약관의 부활(효력회복))","x":89,"y":374,"w":374,"h":22},{"content":"●","x":559,"y":374,"w":21,"h":22},{"content":"회사는 이 특별약관의 부활 청약을 받은 경우에는 보험계약의","x":89,"y":411,"w":501,"h":20},{"content":"부활(효력회복)을 승낙한 경우에 한하여 보통약관 제1절 일반","x":89,"y":436,"w":494,"h":20},{"content":"조항 제28조(보험료의 납입을 연체하여 해지된 계약의 부활(효","x":89,"y":462,"w":494,"h":20},{"content":"력회복))을 취급합니다.","x":89,"y":487,"w":176,"h":20},{"content":"제4조(준용규정)","x":89,"y":547,"w":147,"h":22},{"content":"●","x":559,"y":547,"w":21,"h":22},{"content":"이 특별약관에 정하지 않은 사항은 보통약관 및 해당 특별약","x":89,"y":584,"w":494,"h":20},{"content":"관의 규정을 따릅니다.","x":89,"y":609,"w":174,"h":20},{"content":"2-4.","x":171,"y":685,"w":47,"h":24},{"content":"지정대리청구서비스 특별약관","x":217,"y":685,"w":282,"h":24},{"content":"제1조(적용대상)","x":89,"y":750,"w":147,"h":22},{"content":"●","x":559,"y":750,"w":21,"h":22},{"content":"이 특별약관은 계약자, 피보험자 및 보험수익자가 모두 동일한","x":89,"y":787,"w":501,"h":20},{"content":"보통약관 및 특별약관에 적용됩니다.","x":89,"y":812,"w":285,"h":20},{"content":"제2조(특약의 체결 및 소멸)","x":89,"y":873,"w":254,"h":22},{"content":"●","x":559,"y":873,"w":21,"h":22},{"content":"① 이 특별약관은 계약자의 청약과 보험회사의 승낙으로 부가","x":89,"y":910,"w":494,"h":20},{"content":"되어집니다.","x":116,"y":935,"w":89,"h":20},{"content":"② 제1조(적용대상)의 보험계약이 해지 또는 기타 사유에 의하","x":89,"y":960,"w":494,"h":20},{"content":"여 효력을 가지지 않게 되는 경우에는 이 특별약관은 더","x":116,"y":985,"w":473,"h":20},{"content":"이상 효력을 가지지 않습니다.","x":116,"y":1011,"w":234,"h":20},{"content":"제3조(지정대리청구인의 지정)","x":89,"y":1071,"w":274,"h":22},{"content":"●","x":559,"y":1071,"w":21,"h":22},{"content":"① 계약자는 보통약관 또는 특별약관에서 정한 보험금을 직접","x":89,"y":1108,"w":501,"h":20},{"content":"청구할 수 없는 특별한 사정이 있을 경우를 대비하여 계약","x":116,"y":1133,"w":467,"h":20},{"content":"체결 시 또는 계약체결 이후 다음 각 호의 어느 하나에 해","x":116,"y":1158,"w":467,"h":20},{"content":"당하는 자 중에서 보험금의 대리청구인(2인 이내에서 지정","x":116,"y":1184,"w":467,"h":20},{"content":"하되, 2인 지정시 대표대리인을 지정, 이하 ‘지정대리청구","x":116,"y":1209,"w":467,"h":20},{"content":"인’이라합니다)을 지정[제4조(지정대리청구인의 변경지정)에","x":116,"y":1234,"w":473,"h":20},{"content":"의한 변경 지정 포함]할 수 있습니다. 다만, 지정대리청구인","x":116,"y":1260,"w":467,"h":20},{"content":"은 보험금 청구시에도 다음 각 호의 어느 하나에 해당하여","x":116,"y":1285,"w":467,"h":20},{"content":"야 합니다.","x":116,"y":1310,"w":81,"h":20},{"content":"1. 피보험자의 가족관계등록부상 또는 주민등록상 배우자","x":115,"y":1335,"w":449,"h":20},{"content":"2. 피보험자의 3촌 이내 친족","x":115,"y":1360,"w":229,"h":20},{"content":"② 제1항에도 불구하고, 지정대리청구인이 지정된 이후에 제1","x":89,"y":1386,"w":494,"h":20},{"content":"조(적용대상)의 보험수익자가 변경되는 경우에는 이미 지정","x":116,"y":1411,"w":467,"h":20},{"content":"된 지정대리청구인의 자격은 자동적으로 상실된 것으로 봅","x":116,"y":1436,"w":467,"h":20},{"content":"니다.","x":116,"y":1461,"w":38,"h":20},{"content":"제4조(지정대리청구인의 변경지정)","x":89,"y":1522,"w":313,"h":22},{"content":"●","x":559,"y":1522,"w":21,"h":22},{"content":"계약자는 다음의 서류를 제출하고 지정대리청구인을 변경 지","x":89,"y":1558,"w":494,"h":20},{"content":"정 할 수 있습니다. 이 경우 회사는 변경 지정을 서면으로 알","x":628,"y":87,"w":494,"h":20},{"content":"리거나 보험증권의 뒷면에 기재하여 드립니다.","x":628,"y":112,"w":362,"h":20},{"content":"1. 지정대리청구인 변경신청서(회사양식)","x":655,"y":137,"w":313,"h":20},{"content":"2. 지정대리청구인의 주민등록등본, 가족관계등록부(기본증","x":655,"y":162,"w":468,"h":20},{"content":"명서 등)","x":676,"y":188,"w":65,"h":20},{"content":"3. 신분증(주민등록증 또는 운전면허증 등 사진이 부착된","x":655,"y":213,"w":475,"h":20},{"content":"정부기관 발행 신분증, 본인이 아닌 경우에는 본인의 인","x":676,"y":238,"w":446,"h":20},{"content":"감증명서, 본인서명사실확인서 또는 안전성과 신뢰성이","x":676,"y":263,"w":453,"h":20},{"content":"확보된 전자적 수단을 활용한 보험수익자 의사표시의 확","x":676,"y":289,"w":446,"h":20},{"content":"인방법 포함)","x":676,"y":314,"w":99,"h":20},{"content":"제5조(보험금 지급 등의 절차)","x":628,"y":374,"w":274,"h":22},{"content":"●","x":1099,"y":374,"w":21,"h":22},{"content":"① 지정대리청구인은 제6조(보험금 등 청구시 구비서류)에 정","x":628,"y":411,"w":494,"h":20},{"content":"한 구비서류 및 제1조(적용대상)의 보험수익자가 보험금을","x":656,"y":436,"w":473,"h":20},{"content":"직접 청구할 수 없는 특별한 사정이 있음을 증명하는 서류","x":656,"y":462,"w":467,"h":20},{"content":"를 제출하고 회사의 승낙을 얻어 제1조(적용대상)의 보험수","x":656,"y":487,"w":467,"h":20},{"content":"익자의 대리인으로서 보험금(사망보험금 제외)을 청구하고","x":656,"y":512,"w":473,"h":20},{"content":"수령할 수 있습니다. 다만, 2인의 지정대리청구인이 지정된","x":656,"y":537,"w":473,"h":20},{"content":"경우에는 그 중 대표대리인이 보험금을 청구하고 수령할","x":656,"y":563,"w":473,"h":20},{"content":"수 있으며, 대표대리인이 사망 등의 사유로 보험금 청구가","x":656,"y":588,"w":473,"h":20},{"content":"불가능한 경우에는 대표대리인이 아닌 지정대리청구인도","x":656,"y":613,"w":473,"h":20},{"content":"보험금을 청구하고 수령할 수 있습니다..","x":656,"y":638,"w":314,"h":20},{"content":"② 회사가 보험금을 지정대리청구인에게 지급한 경우에는 그","x":628,"y":663,"w":501,"h":20},{"content":"이후 보험금 청구를 받더라도 회사는 이를 지급하지 않습","x":656,"y":689,"w":467,"h":20},{"content":"니다.","x":656,"y":714,"w":38,"h":20},{"content":"제6조(보험금 등 청구시 구비서류)","x":628,"y":774,"w":313,"h":22},{"content":"●","x":1099,"y":774,"w":21,"h":22},{"content":"지정대리청구인은 회사가 정하는 방법에 따라 다음의 서류를","x":628,"y":811,"w":501,"h":20},{"content":"제출하고 보험금을 청구하여야 합니다.","x":628,"y":836,"w":302,"h":20},{"content":"1. 청구서(회사양식)","x":655,"y":862,"w":152,"h":20},{"content":"2. 사고증명서(장해진단서, 입원치료확인서 등)","x":655,"y":887,"w":359,"h":20},{"content":"3. 신분증(주민등록증 또는 운전면허증 등 사진이 부착된","x":655,"y":912,"w":475,"h":20},{"content":"정부기관 발행 신분증)","x":676,"y":938,"w":176,"h":20},{"content":"4. 피보험자 및 지정대리청구인의 가족관계등록부(가족관계","x":655,"y":963,"w":468,"h":20},{"content":"증명서) 및 주민등록등본","x":676,"y":988,"w":194,"h":20},{"content":"5. 기타 지정대리청구인이 보험금 등의 수령에 필요하여 제","x":655,"y":1013,"w":468,"h":20},{"content":"출하는 서류","x":676,"y":1038,"w":96,"h":20},{"content":"제7조(준용규정)","x":628,"y":1099,"w":147,"h":22},{"content":"●","x":1099,"y":1099,"w":21,"h":22},{"content":"이 특별약관에 정하지 않은 사항은 보통약관 및 해당 특별약","x":628,"y":1136,"w":494,"h":20},{"content":"관의 규정을 따릅니다.","x":628,"y":1161,"w":174,"h":20},{"content":"2-5.","x":728,"y":1237,"w":47,"h":24},{"content":"제재위반 부담보 특별약관","x":774,"y":1237,"w":248,"h":24},{"content":"제1조(적용대상)","x":628,"y":1302,"w":147,"h":22},{"content":"●","x":1099,"y":1302,"w":21,"h":22},{"content":"이 특별약관은 보통약관 및 다른 특별약관에 우선 적용됩니다.","x":628,"y":1339,"w":489,"h":20},{"content":"제2조(제재위반 부담보)","x":628,"y":1399,"w":215,"h":22},{"content":"●","x":1099,"y":1399,"w":21,"h":22},{"content":"회사는 아래의 제재(이하 ‘제재사항’이라 합니다)에 반하는 위","x":628,"y":1436,"w":494,"h":20},{"content":"험의 보장, 보험금의 지급 또는 이익의 제공을 하지 아니합니","x":628,"y":1461,"w":494,"h":20},{"content":"다.","x":628,"y":1487,"w":21,"h":20},{"content":"1. UN 결의에 의한 제재, 금지, 제한사항","x":655,"y":1512,"w":320,"h":20},{"content":"2. EU, 영국 또는 미국의 무역·경제적 제재조치 또는 법률","x":655,"y":1537,"w":468,"h":20},{"content":"규정","x":676,"y":1562,"w":36,"h":20},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000109) 【 109/139 】","x":667,"y":26,"w":225,"h":16},{"content":"<109>","x":1096,"y":26,"w":48,"h":16}]}