content":"지급합니다.","x":617,"y":814,"w":89,"h":20},{"content":"② 회사는 피보험자가 보험증권에 기재된 이 특별약관의 보험","x":591,"y":839,"w":492,"h":20},{"content":"기간(이하 ‘보험기간’이라 합니다) 중에 제3조(보험금 지급","x":617,"y":864,"w":466,"h":20},{"content":"에 관한 세부규정) 제1항에서 정한 보장개시일 이후에 제4","x":617,"y":889,"w":467,"h":20},{"content":"조(‘암’의 정의 및 진단확정)에서 정한 ‘갑상선암’ 또는 ‘전립","x":617,"y":914,"w":466,"h":20},{"content":"선암’ 으로 진단 확정되고, 그 ‘갑상선암’ 또는 ‘전립선암’의","x":617,"y":940,"w":473,"h":20},{"content":"직접적인 치료를 목적으로 ‘다빈치로봇 암수술’을 받은 경","x":617,"y":965,"w":466,"h":20},{"content":"우 최초 1회에 한하여 아래의 금액을 다빈치로봇 갑상선암","x":617,"y":990,"w":473,"h":20},{"content":"및 전립선암 수술비로 보험수익자에게 지급합니다.","x":617,"y":1015,"w":394,"h":20},{"content":"구분","x":655,"y":1081,"w":35,"h":20},{"content":"지급금액","x":878,"y":1043,"w":68,"h":20},{"content":"최초계약","x":845,"y":1069,"w":68,"h":20},{"content":"갱신","x":1032,"y":1082,"w":35,"h":20},{"content":"계약","x":1032,"y":1106,"w":35,"h":20},{"content":"계약일 후","x":779,"y":1095,"w":77,"h":20},{"content":"1년 미만","x":783,"y":1119,"w":69,"h":20},{"content":"계약일 후","x":916,"y":1095,"w":77,"h":20},{"content":"1년 이상","x":920,"y":1119,"w":69,"h":20},{"content":"다빈치로봇","x":631,"y":1146,"w":90,"h":20},{"content":"암수술비(갑상선","x":613,"y":1171,"w":120,"h":20},{"content":"암 및 전립선암","x":615,"y":1196,"w":122,"h":20},{"content":"제외)","x":654,"y":1221,"w":38,"h":20},{"content":"(최초 1회한)","x":627,"y":1246,"w":92,"h":20},{"content":"이 특별약관","x":772,"y":1171,"w":91,"h":20},{"content":"보험가입금액의","x":760,"y":1196,"w":122,"h":20},{"content":"50% 해당액","x":773,"y":1221,"w":90,"h":20},{"content":"이 특별약관","x":943,"y":1171,"w":91,"h":20},{"content":"보험가입금액의","x":931,"y":1196,"w":115,"h":20},{"content":"100% 해당액","x":939,"y":1221,"w":99,"h":20},{"content":"다빈치로봇","x":631,"y":1280,"w":90,"h":20},{"content":"갑상선암 및","x":627,"y":1305,"w":98,"h":20},{"content":"전립선암 수술비","x":611,"y":1331,"w":123,"h":20},{"content":"(최초 1회한)","x":627,"y":1356,"w":92,"h":20},{"content":"이 특별약관","x":772,"y":1293,"w":91,"h":20},{"content":"보험가입금액의","x":760,