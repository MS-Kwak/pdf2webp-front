{"texts":[{"content":"07326","x":719,"y":1574,"w":41,"h":16},{"content":"서울시영등포구국제금융로","x":760,"y":1573,"w":170,"h":17},{"content":"10","x":932,"y":1574,"w":17,"h":16},{"content":"국제금융센터","x":949,"y":1573,"w":81,"h":17},{"content":"Two IFC 27","x":1033,"y":1574,"w":70,"h":16},{"content":"층","x":1102,"y":1573,"w":15,"h":16},{"content":"AIG","x":876,"y":1606,"w":46,"h":28},{"content":"손해보험주식회사","x":923,"y":1604,"w":194,"h":26},{"content":"청약서","x":229,"y":75,"w":121,"h":44},{"content":"무배당 AIG 든든한 간편암보험2604(325간편심사형)(10년갱신형)","x":81,"y":146,"w":1039,"h":36},{"content":"청약번호 : 942696462419","x":885,"y":197,"w":252,"h":22},{"content":"계약자보관용","x":1020,"y":229,"w":115,"h":20},{"content":"※ 본 청약서는 계약자, 피보험자(보험대상자) 본인이 사실대로 직접 작성하","x":69,"y":293,"w":488,"h":17},{"content":"였으며, 피보험자(보험대상자)의 서면상 동의를 얻어 청약하였고, 보험약관,","x":69,"y":312,"w":506,"h":17},{"content":"계약자보관용청약서를 받았으며, 약관의 주요내용 및 품질보증에 대한","x":69,"y":331,"w":470,"h":17},{"content":"안내를 받았음을 확인합니다.","x":69,"y":350,"w":204,"h":17},{"content":"※ 계약 전 알릴 의무사항에 대한 답변내용은 사실과 일치하며, 보험계약자","x":69,"y":369,"w":484,"h":17},{"content":"및 피보험자(보험대상자) 본인이 직접 작성하였음을 확인합니다. 또한","x":69,"y":388,"w":463,"h":17},{"content":"귀사가 이 사항과 관련하여 필요시에는 별도의 확인을 할 수 있으며,","x":69,"y":407,"w":453,"h":17},{"content":"의사가 본인의 질병 등 건강상태를 조회하거나 열람토록 하는 것에 동의합","x":69,"y":425,"w":490,"h":17},{"content":"니다.","x":69,"y":444,"w":50,"h":17},{"content":"※ 본인(보험계약자)이 보험수익자 지정·변경 추가약정에 약정함을 선택하고","x":69,"y":463,"w":503,"h":17},{"content":"사망한 경우, 상속인 등 승계인이 보험수익자 지정·변경권을 행사하는","x":69,"y":482,"w":474,"h":17},{"content":"것에 동의합니다.","x":69,"y":501,"w":127,"h":17},{"content":"※ 타인의 사망을 보험금 지급사유로 하는 보험계약에서","x":69,"y":520,"w":363,"h":17},{"content":"'서면으로 동의한(서명한)' 피보험자는 계약의 효력이 유지되는 기간에는","x":69,"y":539,"w":476,"h":17},{"content":"언제든지 '서면동의를 철회' 할 수 있습니다. 피보험자가 서면동의를 철회","x":69,"y":557,"w":482,"h":17},{"content":"하는 경우 보험계약은 해지되며 회사가 지급하여야 할 해약환급금이","x":69,"y":576,"w":453,"h":17},{"content":"있을 때에는 보험계약자에게 지급합니다.","x":69,"y":595,"w":282,"h":17},{"content":"※ 이 계약은 보험업감독규정 제4-37조에 따라 음성녹취로 자필서명을 갈음하는","x":600,"y":454,"w":525,"h":17},{"content":"계약으로, 청약녹취 내용을 확인하실수 있습니다.","x":600,"y":477,"w":336,"h":17},{"content":"(청약녹취 확인 연락처 : 당사 고객서비스센터(1544-2792))","x":600,"y":499,"w":401,"h":17},{"content":"상품개발자","x":69,"y":1582,"w":80,"h":16},{"content":":  윤인선((02)2260-6800)","x":166,"y":1582,"w":185,"h":16},{"content":"모집인소속","x":69,"y":1602,"w":80,"h":16},{"content":":  보험대리점 ㈜에이아이지어드바이저_LTC2(AA)","x":166,"y":1602,"w":348,"h":16},{"content":"모 집 인","x":69,"y":1622,"w":80,"h":16},{"content":":  위지영 (고유번호 : 20150485120007)","x":166,"y":1622,"w":283,"h":16},{"content":"연 락 처","x":69,"y":1641,"w":80,"h":16},{"content":":  (02)6430-4700","x":166,"y":1640,"w":129,"h":16},{"content":"고객센터","x":69,"y":1660,"w":80,"h":16},{"content":":  1544-2792","x":166,"y":1660,"w":96,"h":16},{"content":"발행일시","x":383,"y":1660,"w":80,"h":16},{"content":":  2026년 04월 10일","x":480,"y":1660,"w":149,"h":16},{"content":"관리번호","x":756,"y":1633,"w":80,"h":16},{"content":":  AIG 상품관리 제2026-4-TM-A035호","x":854,"y":1633,"w":284,"h":16},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000007) 【 7/139 】","x":685,"y":26,"w":206,"h":16},{"content":"<7>","x":1114,"y":26,"w":29,"h":16}]}