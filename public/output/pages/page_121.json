{"texts":[{"content":"항 목","x":129,"y":94,"w":43,"h":20},{"content":"내 용","x":321,"y":94,"w":43,"h":20},{"content":"점수","x":522,"y":94,"w":35,"h":20},{"content":"검사","x":134,"y":136,"w":36,"h":20},{"content":"소견","x":134,"y":162,"w":36,"h":20},{"content":"양측 전정기능 소실","x":195,"y":124,"w":155,"h":20},{"content":"양측 전정기능 감소","x":195,"y":149,"w":155,"h":20},{"content":"일측 전정기능 소실","x":195,"y":175,"w":155,"h":20},{"content":"14","x":530,"y":124,"w":20,"h":20},{"content":"10","x":530,"y":149,"w":20,"h":20},{"content":"4","x":535,"y":175,"w":10,"h":20},{"content":"치료","x":134,"y":240,"w":36,"h":20},{"content":"병력","x":134,"y":266,"w":36,"h":20},{"content":"장기 통원치료(1년간 12회이상)","x":195,"y":215,"w":243,"h":20},{"content":"장기 통원치료(1년간 6회이상)","x":195,"y":241,"w":234,"h":20},{"content":"단기 통원치료(6개월간 6회이상)","x":195,"y":266,"w":251,"h":20},{"content":"단기 통원치료(6개월간 6회미만)","x":195,"y":291,"w":251,"h":20},{"content":"6","x":535,"y":215,"w":10,"h":20},{"content":"4","x":535,"y":241,"w":10,"h":20},{"content":"2","x":535,"y":266,"w":10,"h":20},{"content":"0","x":535,"y":291,"w":10,"h":20},{"content":"기능","x":134,"y":368,"w":36,"h":20},{"content":"장해","x":134,"y":394,"w":36,"h":20},{"content":"소견","x":134,"y":421,"w":36,"h":20},{"content":"두 눈을 감고 일어서기 곤란하거나 두 눈","x":195,"y":319,"w":296,"h":20},{"content":"을 뜨고 10m 거리를 직선으로 걷다가 쓰","x":195,"y":344,"w":296,"h":20},{"content":"러지는 경우","x":195,"y":369,"w":88,"h":20},{"content":"두 눈을 뜨고 10m 거리를 직선으로 걷다가","x":195,"y":394,"w":303,"h":20},{"content":"중간에 균형을 잡으려 멈추어야 하는 경우","x":195,"y":420,"w":286,"h":20},{"content":"두 눈을 뜨고 10m 거리를 직선으로 걸을","x":195,"y":445,"w":303,"h":20},{"content":"때 중앙에서 60cm 이상 벗어나는 경우","x":195,"y":470,"w":279,"h":20},{"content":"20","x":530,"y":319,"w":20,"h":20},{"content":"12","x":530,"y":394,"w":20,"h":20},{"content":"8","x":535,"y":445,"w":10,"h":20},{"content":"2) 평형기능의 장해는 장해판정 직전 1년 이상 지속적인","x":129,"y":501,"w":461,"h":20},{"content":"치료 후 장해가 고착되었을 때 판정하며, 뇌병변 여","x":160,"y":527,"w":423,"h":20},{"content":"부, 전정기능 이상 및 장해상태를 평가하기 위해 아래","x":160,"y":552,"w":423,"h":20},{"content":"의 검사들을 기초로 한다.","x":160,"y":577,"w":200,"h":20},{"content":"가) 뇌영상검사(CT, MRI)","x":157,"y":602,"w":189,"h":20},{"content":"나) 온도안진검사, 전기안진검사(또는 비디오안진검사)등","x":157,"y":628,"w":410,"h":20},{"content":"3. 코의 장해","x":89,"y":673,"w":109,"h":22},{"content":"가. 장해의 분류","x":115,"y":701,"w":124,"h":20},{"content":"장해의 분류","x":261,"y":733,"w":94,"h":20},{"content":"지급률","x":516,"y":733,"w":51,"h":20},{"content":"1) 코의 호흡기능을 완전히 잃었을 때","x":128,"y":761,"w":297,"h":20},{"content":"2) 코의 후각기능을 완전히 잃었을 때","x":128,"y":787,"w":297,"h":20},{"content":"15","x":532,"y":761,"w":20,"h":20},{"content":"5","x":537,"y":787,"w":10,"h":20},{"content":"나. 장해판정기준","x":115,"y":819,"w":132,"h":20},{"content":"1) ‘코의 호흡기능을 완전히 잃었을 때’라 함은 일상생활","x":129,"y":844,"w":454,"h":20},{"content":"에서 구강(입속)호흡의 보조를 받지 않는 상태에서 코","x":160,"y":869,"w":423,"h":20},{"content":"로 숨쉬는 것만으로 정상적인 호흡을 할 수 없다는","x":160,"y":894,"w":430,"h":20},{"content":"것이 비강통기도검사 등 의학적으로 인정된 검사로","x":160,"y":920,"w":430,"h":20},{"content":"확인되는경우를 말한다.","x":160,"y":945,"w":183,"h":20},{"content":"2) ‘코의 후각기능을 완전히 잃었을 때’라 함은 후각신경","x":129,"y":970,"w":454,"h":20},{"content":"의손상으로 인하여 양쪽 코의 후각기능을 완전히 잃","x":160,"y":995,"w":423,"h":20},{"content":"은 경우를 말하며, 후각감퇴는 장해의 대상으로 하지","x":160,"y":1021,"w":430,"h":20},{"content":"않는다.","x":160,"y":1046,"w":55,"h":20},{"content":"3) 양쪽 코의 후각기능은 후각인지검사, 후각역치검사 등","x":129,"y":1071,"w":454,"h":20},{"content":"을 통해 6개월 이상 고정된 후각의 완전손실이 확인","x":160,"y":1096,"w":423,"h":20},{"content":"되어야 한다.","x":160,"y":1122,"w":98,"h":20},{"content":"4) 코의 추상(추한 모습)장해를 수반한 때에는 기능장해의","x":129,"y":1147,"w":454,"h":20},{"content":"지급률과 추상장해의 지급률을 합산한다.","x":160,"y":1172,"w":319,"h":20},{"content":"4. 씹어 먹거나 말하는 장해","x":89,"y":1217,"w":240,"h":22},{"content":"가. 장해의 분류","x":115,"y":1245,"w":124,"h":20},{"content":"나. 장해판정기준","x":655,"y":223,"w":132,"h":20},{"content":"1) 씹어먹는 기능의 장해는 윗니(상악치아)와 아랫니(하악치","x":669,"y":248,"w":454,"h":20},{"content":"아)의 맞물림(교합), 배열상태 및 아래턱의 개구(입을 벌","x":700,"y":273,"w":423,"h":20},{"content":"림)운동, 삼킴(연하)운동 등에 따라 종합적으로 판단하여","x":700,"y":298,"w":430,"h":20},{"content":"결정한다.","x":700,"y":324,"w":68,"h":20},{"content":"2) ‘씹어먹는 기능에 심한 장해를 남긴 때’라 함은 심한","x":669,"y":349,"w":461,"h":20},{"content":"개구(입을 벌림)운동 제한이나 저작(씹기)운동 제한으","x":700,"y":374,"w":423,"h":20},{"content":"로 물이나 이에 준하는 음료 이외는 섭취하지 못하는","x":700,"y":400,"w":430,"h":20},{"content":"경우를 말한다.","x":700,"y":425,"w":115,"h":20},{"content":"3) ‘씹어먹는 기능에 뚜렷한 장해를 남긴 때’라 함은 아래","x":669,"y":450,"w":454,"h":20},{"content":"의 경우 중 하나 이상에 해당되는 때를 말한다.","x":700,"y":475,"w":370,"h":20},{"content":"가) 뚜렷한 개구(입을 벌림)운동 제한 또는 뚜렷한 저","x":697,"y":500,"w":426,"h":20},{"content":"작(씹기)운동 제한으로 미음 또는 이에 준하는 정","x":728,"y":526,"w":395,"h":20},{"content":"도의 음식물(죽 등)이외는 섭취하지 못하는 경우","x":728,"y":551,"w":378,"h":20},{"content":"나) 위·아래턱(상·하악)의 가운데 앞니(중절치)간 최대","x":697,"y":576,"w":432,"h":20},{"content":"개구(입을 벌림)운동이 1cm이하로 제한되는 경우","x":728,"y":601,"w":379,"h":20},{"content":"다) 위·아래턱(상·하악)의 부정교합(전방, 측방)이 1.5cm","x":697,"y":627,"w":426,"h":20},{"content":"이상인 경우","x":728,"y":652,"w":96,"h":20},{"content":"라) 1개 이하의 치아만 교합되는 상태","x":697,"y":677,"w":297,"h":20},{"content":"마) 연하기능검사(비디오 투시검사)상 연하장애가 있","x":697,"y":702,"w":426,"h":20},{"content":"고, 유동식 섭취 시 흡인(바늘이나 관을 통하여 내","x":728,"y":728,"w":395,"h":20},{"content":"용물을 빨아들임)이 발생하고 연식 외에는 섭취가","x":728,"y":753,"w":402,"h":20},{"content":"불가능한 상태","x":728,"y":778,"w":113,"h":20},{"content":"4) ‘씹어먹는 기능에 약간의 장해를 남긴 때’라 함은 아래","x":669,"y":803,"w":454,"h":20},{"content":"의 경우 중 하나 이상에 해당되는 때를 말한다.","x":700,"y":828,"w":370,"h":20},{"content":"가) 약간의 개구(입을 벌림)운동 제한 또는 약간의 저작","x":697,"y":854,"w":426,"h":20},{"content":"(씹기)운동 제한으로 부드러운 고형식(밥, 빵 등)만 섭","x":728,"y":879,"w":395,"h":20},{"content":"취 가능한 경우","x":728,"y":904,"w":114,"h":20},{"content":"나) 위·아래턱(상·하악)의 가운데 앞니(중절치)간 최대","x":697,"y":930,"w":432,"h":20},{"content":"개구(입을 벌림)운동이 2cm이하로 제한되는 경우","x":728,"y":955,"w":379,"h":20},{"content":"다) 위·아래턱(상·하악)의 부정교합(전방, 측방)이 1cm","x":697,"y":980,"w":426,"h":20},{"content":"이상인 경우","x":728,"y":1005,"w":96,"h":20},{"content":"라) 양측 각 1개 또는 편측 2개 이하의 치아만 교합","x":697,"y":1030,"w":426,"h":20},{"content":"되는 상태","x":728,"y":1056,"w":79,"h":20},{"content":"마) 연하기능검사(비디오 투시검사)상 연하장애가 있","x":697,"y":1081,"w":426,"h":20},{"content":"고, 유동식 섭취시 간헐적으로 흡인(바늘이나 관을","x":728,"y":1106,"w":401,"h":20},{"content":"통하여 내용물을 빨아들임)이 발생하고 부드러운","x":728,"y":1131,"w":402,"h":20},{"content":"고형식 외에는 섭취가 불가능한 상태","x":728,"y":1157,"w":291,"h":20},{"content":"5) 개구(입을 벌림)장해는 턱관절의 이상으로 개구(입을 벌","x":669,"y":1182,"w":454,"h":20},{"content":"림)운동 제한이 있는 상태를 말하며, 최대 개구(입을","x":700,"y":1207,"w":430,"h":20},{"content":"벌림)상태에서 위·아래턱(상·하악)의 가운데 앞니(중절","x":700,"y":1232,"w":423,"h":20},{"content":"치)간 거리를 기준으로 한다. 단, 가운데 앞니(중절치)","x":700,"y":1258,"w":423,"h":20},{"content":"가 없는 경우에는 측정가능한 인접 치아간 거리의 최","x":700,"y":1283,"w":423,"h":20},{"content":"대치를 기준으로 한다.","x":700,"y":1308,"w":174,"h":20},{"content":"6) 부정교합은 위턱(상악)과 아래턱(하악)의 부조화로 윗","x":669,"y":1333,"w":454,"h":20},{"content":"니(상악치아)와 아랫니(하악치아)가 전방 및 측방으로","x":700,"y":1358,"w":430,"h":20},{"content":"맞물림에 제한이 있는 상태를 말한다.","x":700,"y":1384,"w":294,"h":20},{"content":"7) ‘말하는 기능에 심한 장해를 남긴 때’라 함은 아래의","x":669,"y":1409,"w":461,"h":20},{"content":"경우 중 하나 이상에 해당되는 때를 말한다.","x":700,"y":1434,"w":345,"h":20},{"content":"가) 언어평가상 자음정확도가 30%미만인 경우","x":697,"y":1460,"w":363,"h":20},{"content":"나) 전실어증, 운동성실어증(브로카실어증)으로 의사소","x":697,"y":1485,"w":426,"h":20},{"content":"통이 불가한 경우","x":728,"y":1510,"w":138,"h":20},{"content":"8) ‘말하는 기능에 뚜렷한 장해를 남긴 때’라 함은 아래의","x":669,"y":1535,"w":461,"h":20},{"content":"경우 중 하나 이상에 해당되는 때를 말한다.","x":692,"y":1560,"w":345,"h":20},{"content":"장해의 분류","x":261,"y":1278,"w":94,"h":20},{"content":"지급률","x":516,"y":1278,"w":51,"h":20},{"content":"1) 씹어먹는 기능과 말하는 기능 모두에 심한","x":128,"y":1307,"w":369,"h":20},{"content":"장해를남긴 때","x":152,"y":1332,"w":113,"h":20},{"content":"2) 씹어먹는 기능에 심한 장해를 남긴 때","x":128,"y":1358,"w":323,"h":20},{"content":"3) 말하는 기능에 심한 장해를 남긴 때","x":128,"y":1383,"w":306,"h":20},{"content":"4) 씹어먹는 기능과 말하는 기능 모두에 뚜렷","x":128,"y":1408,"w":362,"h":20},{"content":"한 장해를 남긴 때","x":152,"y":1433,"w":147,"h":20},{"content":"5) 씹어먹는 기능 또는 말하는 기능에 뚜렷한","x":128,"y":1459,"w":369,"h":20},{"content":"장해를 남긴 때","x":152,"y":1484,"w":121,"h":20},{"content":"6) 씹어먹는 기능과 말하는 기능 모두에 약간","x":128,"y":1509,"w":362,"h":20},{"content":"의 장해를 남긴 때","x":152,"y":1534,"w":147,"h":20},{"content":"7) 씹어먹는 기능 또는 말하는 기능에 약간의","x":128,"y":1559,"w":369,"h":20},{"content":"100","x":528,"y":1307,"w":29,"h":20},{"content":"80","x":532,"y":1358,"w":20,"h":20},{"content":"60","x":532,"y":1383,"w":20,"h":20},{"content":"40","x":532,"y":1408,"w":20,"h":20},{"content":"20","x":532,"y":1459,"w":20,"h":20},{"content":"10","x":532,"y":1509,"w":20,"h":20},{"content":"5","x":537,"y":1559,"w":10,"h":20},{"content":"장해의 분류","x":801,"y":94,"w":94,"h":20},{"content":"지급률","x":1056,"y":94,"w":52,"h":20},{"content":"장해를 남긴 때","x":692,"y":121,"w":121,"h":20},{"content":"8) 치아에 14개 이상의 결손이 생긴 때","x":668,"y":146,"w":308,"h":20},{"content":"9) 치아에 7개 이상의 결손이 생긴 때","x":668,"y":172,"w":298,"h":20},{"content":"10) 치아에 5개 이상의 결손이 생긴 때","x":668,"y":197,"w":308,"h":20},{"content":"20","x":1072,"y":146,"w":20,"h":20},{"content":"10","x":1072,"y":172,"w":20,"h":20},{"content":"5","x":1077,"y":197,"w":10,"h":20},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000121) 【 121/139 】","x":667,"y":26,"w":225,"h":16},{"content":"<121>","x":1096,"y":26,"w":48,"h":16}]}