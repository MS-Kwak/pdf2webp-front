{"texts":[{"content":"무배당 AIG 든든한","x":196,"y":108,"w":268,"h":32},{"content":"간편암보험2604(325간편심사형)","x":103,"y":149,"w":466,"h":32},{"content":"보통약관","x":262,"y":191,"w":124,"h":32},{"content":"제1절 일반조항","x":231,"y":288,"w":186,"h":28},{"content":"제1장 목적 및 용어의 정의","x":186,"y":386,"w":276,"h":26},{"content":"제1조(목적)","x":77,"y":452,"w":108,"h":22},{"content":"●","x":547,"y":452,"w":21,"h":22},{"content":"이 보험계약(이하 ‘계약’이라 합니다)은 보험계약자(이하 ‘계약","x":77,"y":489,"w":494,"h":20},{"content":"자’라 합니다)와 보험회사(이하 ‘회사’라 합니다) 사이에 피보험","x":77,"y":514,"w":494,"h":20},{"content":"자의 질병에 대한 위험을 보장하기 위하여 체결됩니다.","x":77,"y":539,"w":430,"h":20},{"content":"제2조(용어의 정의)","x":77,"y":600,"w":176,"h":22},{"content":"●","x":547,"y":600,"w":21,"h":22},{"content":"이 계약에서 사용되는 용어의 정의는, 이 계약의 다른 조항에","x":77,"y":637,"w":494,"h":20},{"content":"서 달리 정의되지 않는 한 다음과 같습니다.","x":77,"y":662,"w":345,"h":20},{"content":"1. 계약관계 관련 용어","x":103,"y":687,"w":177,"h":20},{"content":"가. 계약자: 회사와 계약을 체결하고 보험료를 납입할 의","x":118,"y":712,"w":454,"h":20},{"content":"무를 지는 사람을 말합니다.","x":148,"y":737,"w":217,"h":20},{"content":"나. 보험수익자: 보험금 지급사유가 발생하는 때에 회사에","x":118,"y":763,"w":461,"h":20},{"content":"보험금을 청구하여 받을 수 있는 사람을 말합니다.","x":148,"y":788,"w":396,"h":20},{"content":"다. 보험증권: 계약의 성립과 그 내용을 증명하기 위하여","x":118,"y":813,"w":461,"h":20},{"content":"회사가 계약자에게 드리는 증서를 말합니다.","x":148,"y":839,"w":345,"h":20},{"content":"라. 진단계약: 계약을 체결하기 위하여 피보험자가 건강진","x":118,"y":864,"w":454,"h":20},{"content":"단을 받아야 하는 계약을 말합니다.","x":148,"y":889,"w":277,"h":20},{"content":"마. 피보험자: 보험사고의 대상이 되는 사람을 말합니다.","x":118,"y":914,"w":437,"h":20},{"content":"2. 지급사유 관련 용어","x":103,"y":939,"w":177,"h":20},{"content":"가. 상해: 보험기간 중에 발생한 급격하고도 우연한 외래","x":118,"y":965,"w":454,"h":20},{"content":"의 사고로 신체(의수, 의족, 의안, 의치 등 신체보조장","x":148,"y":990,"w":423,"h":20},{"content":"구는 제외하나, 인공장기나 부분 의치 등 신체에 이식","x":148,"y":1015,"w":423,"h":20},{"content":"되어 그 기능을 대신할 경우는 포함합니다)에 입은","x":148,"y":1040,"w":430,"h":20},{"content":"상해를 말합니다.","x":148,"y":1066,"w":132,"h":20},{"content":"나. 장해: ‘[별표12] 장해분류표’에서 정한 기준에 따른 장","x":118,"y":1091,"w":454,"h":20},{"content":"해상태를 말합니다.","x":148,"y":1116,"w":149,"h":20},{"content":"다. 한국표준질병·사인분류: 제9차 개정 한국표준질병·사인","x":118,"y":1141,"w":454,"h":20},{"content":"분류(통계청 고시 제2025-299호, 2026.1.1 시행)를 말","x":148,"y":1167,"w":423,"h":20},{"content":"하며 이후 한국표준질병·사인분류가 개정되는 경우는","x":148,"y":1192,"w":430,"h":20},{"content":"개정된 기준에 따라 이 약관에서 보장하는 질병(상병)","x":148,"y":1217,"w":430,"h":20},{"content":"해당 여부를 판단합니다.","x":148,"y":1242,"w":191,"h":20},{"content":"• 대상 질병(상병) 분류표의 분류번호와 다르나 한국","x":148,"y":1267,"w":423,"h":20},{"content":"표준질병·사인분류의 기준에 따라 분류번호를 동시에","x":148,"y":1293,"w":430,"h":20},{"content":"부여가 가능한 경우 대상 질병(상병) 분류에 포함합니","x":148,"y":1318,"w":423,"h":20},{"content":"다.","x":148,"y":1343,"w":21,"h":20},{"content":"• 제10차 개정 이후 이 약관에서 보장하는 질병(상병)","x":148,"y":1369,"w":430,"h":20},{"content":"해당여부는 피보험자가 진단된 당시 시행되고 있는","x":148,"y":1394,"w":430,"h":20},{"content":"한국표준질병·사인분류에 따라 판단합니다.","x":148,"y":1419,"w":331,"h":20},{"content":"• 진단서 상의 분류번호는 한국표준질병·사인분류 질","x":148,"y":1444,"w":423,"h":20},{"content":"병코딩지침서에 따라 기재된 것을 인정합니다.","x":148,"y":1469,"w":362,"h":20},{"content":"진단 당시의 한국표준질병·사인분류에 따라 이 약관","x":151,"y":1495,"w":421,"h":20},{"content":"에서 보장하는 질병(상병)에 대한 보험금 지급여부가","x":151,"y":1520,"w":427,"h":20},{"content":"판단된 경우, 이후 한국표준질병·사인분류 개정으로","x":151,"y":1545,"w":427,"h":20},{"content":"질병(상병)분류가 변경되더라도 이 약관에서 보장하","x":691,"y":87,"w":421,"h":20},{"content":"는 질병(상병) 해당여부를 다시 판단하지 않습니다.","x":691,"y":112,"w":398,"h":20},{"content":"라. 중요한 사항: 계약 전 알릴 의무와 관련하여 회사가","x":657,"y":137,"w":461,"h":20},{"content":"그 사실을 알았더라면 계약의 청약을 거절하거나 보","x":688,"y":162,"w":423,"h":20},{"content":"험가입금액 한도 제한, 일부 보장 제외, 보험금 삭감,","x":688,"y":188,"w":430,"h":20},{"content":"보험료 할증과 같이 조건부로 승낙하는 등 계약 승낙","x":688,"y":213,"w":423,"h":20},{"content":"에 영향을 미칠 수 있는 사항을 말합니다.","x":688,"y":238,"w":328,"h":20},{"content":"3. 지급금과 이자율 관련 용어","x":643,"y":263,"w":236,"h":20},{"content":"가. 연단위 복리: 회사가 지급할 금전에 이자를 줄 때 1년","x":657,"y":289,"w":454,"h":20},{"content":"마다 마지막 날에 그 이자를 원금에 더한 금액을 다","x":688,"y":314,"w":423,"h":20},{"content":"음 1년의 원금으로 하는 이자 계산방법을 말합니다.","x":688,"y":339,"w":405,"h":20},{"content":"예시) 1차년도 이자 : 10원(100원(원금)×10%(이율))","x":684,"y":364,"w":397,"h":20},{"content":"2차년도 이자 : 11원(110원(원금+1차년도 이자)","x":684,"y":390,"w":437,"h":20},{"content":"×10%(이율))","x":684,"y":415,"w":146,"h":20},{"content":"나. 평균공시이율: 전체 보험회사 공시이율의 평균으로,","x":657,"y":440,"w":461,"h":20},{"content":"이 계약 체결 시점의 이율을 말합니다. 이 평균공시이","x":688,"y":465,"w":423,"h":20},{"content":"율은 금융감독원홈페이지(www.fss.or.kr)의 [업무자료/","x":688,"y":490,"w":423,"h":20},{"content":"보험업무] 내 [보험상품자료]에서 확인할 수 있습니다.","x":688,"y":516,"w":420,"h":20},{"content":"다. 해약환급금: 계약이 해지되는 때에 회사가 계약자에게","x":657,"y":541,"w":461,"h":20},{"content":"돌려주는 금액을 말합니다.","x":688,"y":566,"w":209,"h":20},{"content":"라. 적용이율: 보험료 산출시 적용한 이율을 말합니다.","x":657,"y":592,"w":420,"h":20},{"content":"마. 이미 납입한 보험료 : 계약자가 실제 납입한 보험료를","x":657,"y":617,"w":461,"h":20},{"content":"말합니다.","x":688,"y":642,"w":72,"h":20},{"content":"4. 기간과 날짜 관련 용어","x":643,"y":667,"w":202,"h":20},{"content":"가. 보험기간: 계약에 따라 보장을 받는 기간을 말합니다.","x":657,"y":692,"w":446,"h":20},{"content":"나. 영업일: 회사가 영업점에서 정상적으로 영업하는 날을","x":657,"y":718,"w":461,"h":20},{"content":"말하며, 토요일, ‘관공서의 공휴일에 관한 규정’에 따","x":688,"y":743,"w":423,"h":20},{"content":"른 공휴일과 근로자의 날을 제외합니다.","x":688,"y":768,"w":311,"h":20},{"content":"관련법규","x":669,"y":817,"w":85,"h":24},{"content":"•••","x":756,"y":817,"w":41,"h":24},{"content":"관공서의 공휴일에 관한 규정 제2조 및 제3조•••","x":669,"y":851,"w":381,"h":20},{"content":"제2조(공휴일)","x":669,"y":902,"w":106,"h":20},{"content":"관공서의 공휴일은 다음 각 호와 같다. 다만, 재외공관의","x":669,"y":927,"w":467,"h":20},{"content":"공휴일은 우리나라의 국경일 중 공휴일과 주재국의 공","x":696,"y":953,"w":432,"h":20},{"content":"휴일로 한다.","x":696,"y":978,"w":98,"h":20},{"content":"1. 일요일","x":669,"y":1003,"w":75,"h":20},{"content":"2. 국경일 중 3","x":669,"y":1028,"w":123,"h":20},{"content":"‧","x":794,"y":1028,"w":5,"h":20},{"content":"1절, 광복절, 개천절 및 한글날","x":799,"y":1028,"w":240,"h":20},{"content":"3. 1월 1일","x":669,"y":1053,"w":85,"h":20},{"content":"4. 설날 전날, 설날, 설날 다음날 (음력 12월 말일, 1월 1","x":669,"y":1079,"w":460,"h":20},{"content":"일, 2일)","x":696,"y":1104,"w":61,"h":20},{"content":"5. 삭제 <2005. 6. 30>","x":669,"y":1129,"w":180,"h":20},{"content":"6. 부처님오신날 (음력 4월 8일)","x":669,"y":1154,"w":247,"h":20},{"content":"7. 5월 5일 (어린이날)","x":669,"y":1180,"w":171,"h":20},{"content":"8. 6월 6일 (현충일)","x":669,"y":1205,"w":154,"h":20},{"content":"9. 추석 전날, 추석, 추석 다음날 (음력 8월 14일, 15일, 16","x":669,"y":1230,"w":460,"h":20},{"content":"일)","x":696,"y":1255,"w":23,"h":20},{"content":"10. 12월 25일(기독탄신일)","x":669,"y":1281,"w":207,"h":20},{"content":"10의2. 「공직선거법」제34조에 따른 임기만료에 의한 선거","x":669,"y":1306,"w":460,"h":20},{"content":"의 선거일","x":696,"y":1331,"w":79,"h":20},{"content":"11. 기타 정부에서 수시 지정하는 날","x":669,"y":1356,"w":289,"h":20},{"content":"제3조(대체공휴일)","x":669,"y":1407,"w":140,"h":20},{"content":"① 제2조 제2호부터 제10호까지의 공휴일이 다음 각 호의","x":669,"y":1432,"w":467,"h":20},{"content":"어느 하나에 해당하는 경우에는 그 공휴일 다음의 첫","x":696,"y":1457,"w":439,"h":20},{"content":"번째 비공휴일(제2조 각 호의 공휴일이 아닌 날을 말","x":696,"y":1483,"w":432,"h":20},{"content":"한다. 이하 같다)을 대체공휴일로 한다.","x":696,"y":1508,"w":302,"h":20},{"content":"1. 제2조 제2호 또는 제7호의 공휴일이 토요일이나 일요","x":669,"y":1533,"w":460,"h":20},{"content":"일과 겹치는 경우","x":696,"y":1558,"w":138,"h":20},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000077) 【 77/139 】","x":676,"y":26,"w":215,"h":16},{"content":"<77>","x":1105,"y":26,"w":39,"h":16}]}