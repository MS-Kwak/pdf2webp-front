{"texts":[{"content":"07326","x":719,"y":1574,"w":41,"h":16},{"content":"서울시영등포구국제금융로","x":760,"y":1573,"w":170,"h":17},{"content":"10","x":932,"y":1574,"w":17,"h":16},{"content":"국제금융센터","x":949,"y":1573,"w":81,"h":17},{"content":"Two IFC 27","x":1033,"y":1574,"w":70,"h":16},{"content":"층","x":1102,"y":1573,"w":15,"h":16},{"content":"AIG","x":876,"y":1606,"w":46,"h":28},{"content":"손해보험주식회사","x":923,"y":1604,"w":194,"h":26},{"content":"상품개발자","x":69,"y":1579,"w":80,"h":16},{"content":"윤인선((02)2260-6800)","x":166,"y":1579,"w":181,"h":16},{"content":"모집인소속","x":69,"y":1597,"w":80,"h":16},{"content":"보험대리점 ㈜에이아이지어드바이저_LTC2(AA)","x":166,"y":1597,"w":343,"h":16},{"content":"모","x":69,"y":1616,"w":15,"h":16},{"content":"집","x":101,"y":1616,"w":15,"h":16},{"content":"인","x":133,"y":1616,"w":15,"h":16},{"content":"위지영 (고유번호 : 20150485120007)","x":166,"y":1616,"w":279,"h":16},{"content":"연","x":69,"y":1635,"w":15,"h":16},{"content":"락","x":101,"y":1635,"w":15,"h":16},{"content":"처","x":133,"y":1635,"w":15,"h":16},{"content":"(02)6430-4700","x":166,"y":1635,"w":124,"h":16},{"content":"발행일시","x":69,"y":1654,"w":80,"h":16},{"content":"2026년 04월 10일","x":166,"y":1654,"w":145,"h":16},{"content":"고객센터","x":69,"y":1673,"w":80,"h":16},{"content":"1544-2792","x":166,"y":1673,"w":91,"h":16},{"content":"상품설명서","x":240,"y":61,"w":200,"h":44},{"content":"무배당 AIG 든든한 간편암보험2604(325간편심사형)(10년갱신형)","x":82,"y":146,"w":1039,"h":36},{"content":"설계번호 : 942696462419","x":886,"y":197,"w":252,"h":22},{"content":"관리번호","x":756,"y":1633,"w":80,"h":16},{"content":":  AIG 상품관리 제2026-4-TM-P035호","x":854,"y":1633,"w":284,"h":16},{"content":"유형","x":140,"y":272,"w":35,"h":19},{"content":"상품설명 불이행 환급 요구","x":190,"y":272,"w":213,"h":19},{"content":"보험설계사가 서명하라고 하여 서명만 하고 상품설명을 제대로 듣지 못하였음으로 계약을 취소하고 보험료를 환","x":136,"y":326,"w":884,"h":19},{"content":"급을 요구.","x":136,"y":351,"w":82,"h":19},{"content":"보험청약 시 청약서, 상품설명서에 보험계약자가 자필로 서명한 것과 보험계약체결 이후 진행되는 완전판매 모니","x":136,"y":382,"w":889,"h":19},{"content":"터링 시행을 통해 약관의 중요내용 설명 이행 등에 대해 설명 들었다고 답변한 사실은 법률적 효력이 있으며, 보","x":136,"y":406,"w":887,"h":19},{"content":"험계약자는 보험증권 등을 수령하면 반드시 보험계약내용을 확인하여야 하며, 이해가 부족한 경우 청약 단계에서","x":136,"y":431,"w":889,"h":19},{"content":"보험설계사에게 추가 설명을 요구하여야 합니다. 보험계약자는 보험증권을 받은 날부터 15일 이내(다만, 청약한","x":136,"y":456,"w":873,"h":19},{"content":"날부터 30일 이내)에 청약을 철회할 수 있으며, 약관 중요내용 설명 미이행 등의 사유에 해당하는 경우 계약이","x":136,"y":481,"w":870,"h":19},{"content":"성립한 날부터 3개월 이내에 계약을 취소할 수 있습니다.","x":136,"y":506,"w":448,"h":19},{"content":"유형","x":141,"y":553,"w":35,"h":19},{"content":"부담보 조건","x":192,"y":553,"w":95,"h":19},{"content":"보험 가입 시 건강검진 시 왼쪽 유방에 양성 석회화 소견을 받은 사실을 고지하고 가입 후 유방암으로 진단 받아","x":135,"y":607,"w":890,"h":19},{"content":"보험금을 청구하자 유방부위에 5년간 부담보 조건으로 가입되어 있어 보험금 지급이 거절됨.","x":135,"y":632,"w":728,"h":19},{"content":"보험계약을 체결할 당시 피보험자의 건강상태가 회사가 정한 기준에 적합하지 않을 경우 특정부위에 발생한 질병","x":135,"y":662,"w":892,"h":19},{"content":"이나 특정 질병에 대하여 면책하는 조건으로 계약을 체결할 수 있으며, 회사가 정한 면책기간(부담보 기간)중에","x":135,"y":687,"w":873,"h":19},{"content":"부담보 부위에 생긴 질병 또는 특정 질병을 직접적인 원인으로 보험금 지급사유가 발생한 경우 보험금을 지급하","x":135,"y":712,"w":883,"h":19},{"content":"지 않으며, 보험료 납입면제 사유가 발생한 경우에 회사는 납입을 면제하지 않습니다. 보험계약 체결 시 부담보","x":135,"y":737,"w":875,"h":19},{"content":"(특정부위·질병 부담보) 조건으로 보험이 가입되었는지 청약서와 증권을 면밀하게 살펴야 합니다.","x":135,"y":762,"w":773,"h":19},{"content":"유형","x":142,"y":809,"w":35,"h":19},{"content":"수익자 지정","x":194,"y":809,"w":95,"h":19},{"content":"자녀가 계약자이고 보험료를 납입하고 있었으나 피보험자 사망 후 보험금을 청구하자 계약자에게 보험금을 지급","x":135,"y":863,"w":884,"h":19},{"content":"하지 않음.","x":135,"y":888,"w":82,"h":19},{"content":"사망보험금 수익자를 지정/변경하고자 할 경우 계약자와 피보험자가 동일하지 않을 때에는 사망보험금 지급사유","x":135,"y":919,"w":884,"h":19},{"content":"가 발생하기 전에 피보험자가 서면으로 동의해야 합니다. 만약 보험수익자를 지정하지 않은 때에는 민법상 피보","x":135,"y":943,"w":880,"h":19},{"content":"험자의 법정상속인 순위로 보험수익자를 정합니다.","x":135,"y":968,"w":397,"h":19},{"content":"▣ 발생 가능한 불이익에 관한 사항","x":106,"y":1005,"w":281,"h":19},{"content":"주의 !","x":137,"y":1046,"w":48,"h":19},{"content":"중도 해지 시 해약환급금에 관한 사항","x":199,"y":1046,"w":298,"h":19},{"content":"중도 해지 시 돌려받는 금액이 지금까지 낸","x":134,"y":1100,"w":348,"h":19},{"content":"보험료보다 적거나 없을","x":481,"y":1100,"w":188,"h":19},{"content":"수 있습니다.","x":668,"y":1100,"w":107,"h":19},{"content":"계약을 중도 해지 시(5년간 보험료 4,780,440원 납입) 위험보험료, 사업비* 등을 빼고 남은 금액을 적용이율로 부","x":134,"y":1131,"w":890,"h":19},{"content":"리한 금액 총 66,694원을 돌려드립니다.","x":134,"y":1155,"w":313,"h":19},{"content":"* 계약의 체결 및 관리 등에 소요되는 비용","x":134,"y":1180,"w":347,"h":19},{"content":"※ 위 예시액은 특정 조건(가입 시 적용이율 1.5%)을 기준으로 산출된 금액이며, 향후","x":134,"y":1205,"w":677,"h":19},{"content":"적용이율 변동 등 여건 변","x":811,"y":1205,"w":204,"h":19},{"content":"화에 따라 환급액이 달라질 수 있습니다.","x":134,"y":1230,"w":320,"h":19},{"content":"☞ 자세한 사항은 설명서의 “해약환급금 예시표” 를 확인하세요.","x":134,"y":1255,"w":524,"h":19},{"content":"주의 !","x":135,"y":1302,"w":48,"h":19},{"content":"보험료 감액제도 이용 시 유의사항","x":195,"y":1302,"w":273,"h":19},{"content":"보험료 감액은 경제 사정 등으로","x":133,"y":1356,"w":264,"h":19},{"content":"불가피한 경우에만 이용","x":396,"y":1356,"w":188,"h":19},{"content":"하세요.","x":583,"y":1356,"w":57,"h":19},{"content":"보험료를 감액하더라도 사업비*는 보험료가 감액된 비율만큼 줄지 않아**, 최초 가입 시 안내받은 만기(해약)환급","x":133,"y":1387,"w":889,"h":19},{"content":"률보다 크게 낮아질 수 있습니다.","x":133,"y":1412,"w":260,"h":19},{"content":"* 해당 보험 계약의 체결 및 관리에 드는 비용 등","x":133,"y":1436,"w":397,"h":19},{"content":"** 보험료를 감액하더라도 사업비 중 일부 항목(계약체결비용 등)은 감액 전과 동일한 경우가 있음","x":133,"y":1461,"w":774,"h":19},{"content":"※ 보험료 감액을 이용하시기 전에 반드시 보험회사 등에 불이익 사항 등을 확인하시길 바랍니다.","x":133,"y":1486,"w":769,"h":19},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000019) 【 19/139 】","x":676,"y":26,"w":215,"h":16},{"content":"<19>","x":1105,"y":26,"w":39,"h":16}]}