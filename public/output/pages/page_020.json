ntent":"※ 갱신형 담보에 관한 더 자세한 내용은 설명서 본문 및 약관을 참조하시기 바랍니다.","x":136,"y":1093,"w":684,"h":19},{"content":"설명서 가. 보험계약 주요체결내용 참고","x":136,"y":1117,"w":312,"h":19},{"content":"주의 !","x":136,"y":1164,"w":48,"h":19},{"content":"고의 사망 시 보험금 지급 면책에 관한 사항","x":198,"y":1164,"w":348,"h":19},{"content":"피보험자 스스로","x":134,"y":1219,"w":137,"h":19},{"content":"고의","x":270,"y":1219,"w":35,"h":19},{"content":"사고로","x":304,"y":1219,"w":68,"h":19},{"content":"사망","x":372,"y":1219,"w":35,"h":19},{"content":"한 때에는","x":406,"y":1219,"w":86,"h":19},{"content":"사망보험금을 지급하지 않습니다.","x":490,"y":1219,"w":261,"h":19},{"content":"다만, 피보험자가 심신상실 등으로 자유롭게 의사 결정을 할 수 없는 상태에서 자신을 해친 경우에는 보험금을","x":134,"y":1249,"w":871,"h":19},{"content":"지급합니다.","x":134,"y":1274,"w":91,"h":19},{"content":"주의 !","x":135,"y":1321,"w":48,"h":19},{"content":"보험금 대리청구인 지정(계약자 = 피보험자 = 수익자인 경우)","x":195,"y":1321,"w":483,"h":19},{"content":"자신을 위해 치매, 장기간병요양자금 담보(특약 포함)에 가입했다면 대리청구인을 꼭 지정하세요.","x":134,"y":1375,"w":761,"h":19},{"content":"치매 등으로 보험에 가입한 사실을 잊거나, 거동 불편 등으로 보험금 청구 불능이 될 우려, 대리청구인 지정으로","x":134,"y":1406,"w":883,"h":19},{"content":"해소할 수 있습니다.","x":134,"y":1431,"w":159,"h":19},{"content":"* 지정대리청구인제도란? 보험계약자, 피보험자 및 보험수익자가 모두 동일한 경우에 치매 등으로 보험금을 직접","x":134,"y":1456,"w":890,"h":19},{"content":"청구할 수 없는 사정에 대비하여 가족 등이 보험금을 대신 청구할 수 있도록 보험계약자가 미리 “대리청구인","x":134,"y":1480,"w":866,"h":19},{"content":"”을 지정할 수 있는 제도입니다.","x":134,"y":1505,"w":260,"h":19},{"content":"11024266116270000020260410160145_20002014280","x":29,"y":9,"w":249,"h":10},{"content":"No : 1(000020) 【 20/139 】","x":676,"y":26,"w":215,"h":16},{"content":"<20>","x":1105,"y":26,"w":39,"h":16}]}